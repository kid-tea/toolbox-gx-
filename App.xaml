<!--
    App.xaml — 应用程序入口
    不使用 StartupUri（通过 DI 创建 MainWindow），
    启动流程由 App.xaml.cs 的 OnStartup 控制
-->
<Application x:Class="Toolbox.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Toolbox"
             xmlns:helpers="clr-namespace:Toolbox.Helpers"
             xmlns:models="clr-namespace:Toolbox.Models"
             DispatcherUnhandledException="OnDispatcherUnhandledException">
    <Application.Resources>
        <!-- ========== 通用值转换器 ========== -->
        <!-- Bool ↔ Visibility -->
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <!-- Invert Bool ↔ Visibility -->
        <helpers:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter"/>
        <helpers:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisConverter"/>
        <helpers:InvertBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <helpers:InvertBoolToVisibilityConverter x:Key="InvBool"/>
        <!-- Invert Bool -->
        <helpers:InvertBoolConverter x:Key="InverseBoolConverter"/>
        <helpers:InvertBoolConverter x:Key="BoolInverseConverter"/>
        <helpers:InvertBoolConverter x:Key="NegateBoolConverter"/>
        <!-- String → Visibility -->
        <helpers:StringToVisibilityConverter x:Key="StringToVisConverter"/>
        <helpers:StringToVisibilityConverter x:Key="StrToVis"/>
        <!-- Bytes → Size -->
        <helpers:BytesToSizeConverter x:Key="BytesToSizeConverter"/>
        <!-- Percentage -->
        <helpers:PercentageConverter x:Key="PercentageConverter"/>
        <!-- Enum Equals -->
        <helpers:EnumEqualsConverter x:Key="EnumEqualsConverter"/>
        <!-- Importance → Visibility -->
        <helpers:ImportanceToVisibilityConverter x:Key="ImportanceToVisibilityConverter"/>
        <!-- Delete Status → Icon -->
        <helpers:DeleteStatusToIconConverter x:Key="StatusToColorConverter"/>
        <helpers:DeleteStatusToIconConverter x:Key="StatusToTextConverter"/>
        <!-- Impact → Background -->
        <helpers:PercentToStringConverter x:Key="ImpactToBackgroundConverter"/>
        <helpers:PercentToStringConverter x:Key="SeverityToBackgroundConverter"/>
        <!-- Zero count → Visibility -->
        <helpers:BoolToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <helpers:ZeroCountToCollapsedConverter x:Key="ZeroCountToCollapsedConverter"/>

        <!-- 全局滚动条：默认细，悬停时加宽可拖动块 -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Root" Background="Transparent" Width="10">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" IsHitTestVisible="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" IsHitTestVisible="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="5" HorizontalAlignment="Center">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="{DynamicResource TextMutedBrush}"
                                                        CornerRadius="3"
                                                        Opacity="0.45"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="Root" Property="Width" Value="Auto"/>
                                <Setter TargetName="Root" Property="Height" Value="10"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter TargetName="Thumb" Property="Width" Value="Auto"/>
                                <Setter TargetName="Thumb" Property="Height" Value="5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Width" Value="9"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Orientation" Value="Horizontal"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Thumb" Property="Width" Value="Auto"/>
                                <Setter TargetName="Thumb" Property="Height" Value="9"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
