<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="CyberBackgroundBrush" Color="{Binding Color, Source={StaticResource ContentBrush}}"/>
    <SolidColorBrush x:Key="CyberCarbonBrush" Color="{Binding Color, Source={StaticResource SidebarBrush}}"/>
    <SolidColorBrush x:Key="CyberPanelBrush" Color="{Binding Color, Source={StaticResource CardBrush}}"/>
    <SolidColorBrush x:Key="CyberCyanBrush" Color="{Binding Color, Source={StaticResource AccentBrush}}"/>
    <SolidColorBrush x:Key="CyberBlueBrush" Color="{Binding Color, Source={StaticResource AccentHoverBrush}}"/>
    <SolidColorBrush x:Key="CyberMagentaBrush" Color="{Binding Color, Source={StaticResource DangerBrush}}"/>
    <SolidColorBrush x:Key="CyberOrangeBrush" Color="{Binding Color, Source={StaticResource WarningBrush}}"/>
    <SolidColorBrush x:Key="CyberPurpleBrush" Color="{Binding Color, Source={StaticResource AccentBrush}}"/>
    <SolidColorBrush x:Key="CyberGreenBrush" Color="{Binding Color, Source={StaticResource SuccessBrush}}"/>
    <SolidColorBrush x:Key="CyberTextBrush" Color="{Binding Color, Source={StaticResource TextPrimaryBrush}}"/>
    <SolidColorBrush x:Key="CyberMutedBrush" Color="{Binding Color, Source={StaticResource TextMutedBrush}}"/>
    <SolidColorBrush x:Key="CyberLineBrush" Color="{Binding Color, Source={StaticResource BorderBrush}}"/>
    <SolidColorBrush x:Key="CyberInputBrush" Color="{Binding Color, Source={StaticResource InputBackgroundBrush}}"/>
    <SolidColorBrush x:Key="CyberHoverBrush" Color="{Binding Color, Source={StaticResource SidebarHoverBrush}}"/>
    <SolidColorBrush x:Key="CyberSelectedBrush" Color="{Binding Color, Source={StaticResource AccentLightBrush}}"/>
    <SolidColorBrush x:Key="CyberFocusBrush" Color="{Binding Color, Source={StaticResource AccentBrush}}"/>
    <SolidColorBrush x:Key="CyberMetricCardBrush" Color="{Binding Color, Source={StaticResource CardBrush}}"/>
    <SolidColorBrush x:Key="CyberMetricCardHoverBrush" Color="{Binding Color, Source={StaticResource SidebarHoverBrush}}"/>
    <SolidColorBrush x:Key="CyberMetricCardPressedBrush" Color="{Binding Color, Source={StaticResource AccentLightBrush}}"/>
    <SolidColorBrush x:Key="CyberTrackerBrush" Color="{Binding Color, Source={StaticResource InputBackgroundBrush}}"/>
    <SolidColorBrush x:Key="CyberAttentionBrush" Color="{Binding Color, Source={StaticResource WarningLightBrush}}"/>
    <SolidColorBrush x:Key="CyberRiskPanelBrush" Color="{Binding Color, Source={StaticResource DangerLightBrush}}"/>
    <SolidColorBrush x:Key="CyberUnsupportedBrush" Color="{Binding Color, Source={StaticResource AccentLightBrush}}"/>

    <DropShadowEffect x:Key="CyberCyanGlow" Color="#6E63F2" BlurRadius="8" ShadowDepth="0" Opacity="0.10"/>
    <DropShadowEffect x:Key="CyberSoftGlow" Color="#000000" BlurRadius="10" ShadowDepth="0" Opacity="0.08"/>
    <DropShadowEffect x:Key="CyberRiskGlow" Color="#FF6B7A" BlurRadius="8" ShadowDepth="0" Opacity="0.12"/>

    <DrawingBrush x:Key="CyberGridBrush" TileMode="Tile" Viewport="0,0,28,28" ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,28,28"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#06000000">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="0,0,1,1"/>
                            <RectangleGeometry Rect="14,14,1,1"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#081D2432" Thickness="0.6"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="28,0"/>
                            <LineGeometry StartPoint="0,0" EndPoint="0,28"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <Style x:Key="CyberPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CyberPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CyberLineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="CyberButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource CyberCyanBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource CyberCyanBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,9"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI, Consolas"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.92"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource CyberFocusBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="CyberGhostButtonStyle" TargetType="Button" BasedOn="{StaticResource CyberButtonStyle}">
        <Setter Property="Background" Value="{StaticResource CyberInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
    </Style>

    <Style x:Key="CyberHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, Consolas"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="CyberMutedTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CyberMutedBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, Consolas"/>
    </Style>

    <Style x:Key="CyberProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="5"/>
        <Setter Property="Foreground" Value="{StaticResource CyberPurpleBrush}"/>
        <Setter Property="Background" Value="#252B3A"/>
    </Style>

    <Style x:Key="CyberTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource CyberInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CyberLineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI, Consolas"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CaretBrush" Value="{StaticResource CyberTextBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="TextBoxBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#3A4358"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{StaticResource CyberFocusBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CyberComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource CyberInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, Consolas"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#2A3042"/>
                            <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#302D4B"/>
                            <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CyberComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource CyberInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CyberLineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, Consolas"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource CyberComboBoxItemStyle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="False"
                                      ClickMode="Press"
                                      Background="Transparent"
                                      BorderThickness="0">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <Border x:Name="BoxBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{TemplateBinding SelectionBoxItem}"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Path Grid.Column="1"
                                          Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="{StaticResource CyberMutedBrush}"
                                          Width="8"
                                          Height="4"
                                          Margin="12,0,0,0"
                                          VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               PopupAnimation="Fade">
                            <Border Background="{StaticResource CyberInputBrush}"
                                    BorderBrush="{StaticResource CyberLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer CanContentScroll="True">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="ToggleButton" Property="IsMouseOver" Value="True">
                            <Setter TargetName="BoxBorder" Property="BorderBrush" Value="#3A4358"/>
                            <Setter TargetName="BoxBorder" Property="Background" Value="{StaticResource CyberHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="BoxBorder" Property="BorderBrush" Value="{StaticResource CyberFocusBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CyberTreeViewItemStyle" TargetType="{x:Type TreeViewItem}">
        <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TreeViewItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ToggleButton x:Name="Expander"
                                      Grid.Column="0"
                                      Width="16"
                                      Height="24"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"
                                      Focusable="False"
                                      Background="Transparent"
                                      BorderThickness="0">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Grid Background="Transparent">
                                        <Path x:Name="Arrow"
                                              Data="M 0 0 L 5 4 L 0 8 Z"
                                              Fill="{StaticResource CyberMutedBrush}"
                                              Width="5"
                                              Height="8"
                                              Stretch="Fill"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Arrow" Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="90" CenterX="2.5" CenterY="4"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource CyberTextBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <Border x:Name="HeaderBorder"
                                Grid.Column="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter x:Name="PART_Header"
                                              ContentSource="Header"
                                              HorizontalAlignment="Stretch"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>

                        <ItemsPresenter x:Name="ItemsHost"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="10,2,0,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="#151A26"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{StaticResource CyberFocusBrush}"/>
                            <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource CyberSelectedBrush}"/>
                            <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="#31394C"/>
                            <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CyberTabControlStyle" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="CyberTabItemStyle" TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource CyberMutedBrush}"/>
        <Setter Property="Background" Value="#1B1F2A"/>
        <Setter Property="BorderBrush" Value="#2C3344"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI, Consolas"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4,4,0,0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                <Setter Property="Background" Value="{StaticResource CyberHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                <Setter Property="Background" Value="{StaticResource CyberHoverBrush}"/>
                <Setter Property="BorderBrush" Value="#3A4358"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
