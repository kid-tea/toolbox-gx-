<!--
    AlwaysOnTopView.xaml — 窗口置顶功能页面
    布局：前台窗口信息 → 置顶按钮 → 已置顶窗口列表 → 一键取消全部
    所有颜色使用 {StaticResource ...} 引用主题
-->
<UserControl x:Class="Toolbox.Views.AlwaysOnTopView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Toolbox.ViewModels"
             Background="{StaticResource ContentBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 前台窗口信息 + 操作按钮 -->
            <RowDefinition Height="Auto"/>   <!-- 状态信息 -->
            <RowDefinition Height="*"/>      <!-- 已置顶窗口列表 -->
            <RowDefinition Height="Auto"/>   <!-- 一键取消全部 + 警告 -->
        </Grid.RowDefinitions>

        <!-- ========== 第1行：前台窗口信息 + 操作按钮 ========== -->
        <Border Grid.Row="0" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource DefaultCornerRadius}" Padding="16" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 前台窗口信息面板 -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="当前前台窗口"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding ForegroundWindowInfo}"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"
                               TextWrapping="Wrap" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="句柄: "
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding ForegroundWindowHandle}"
                                   Foreground="{StaticResource AccentBrush}" FontSize="11"
                                   FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>

                <!-- 操作按钮组 -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="↻ 刷新前台窗口"
                            Command="{Binding RefreshForegroundWindowCommand}"
                            Padding="12,6" Margin="0,0,0,8"
                            Background="{StaticResource InputBackgroundBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            Cursor="Hand" FontSize="12">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="📌 置顶前台窗口"
                            Command="{Binding TopmostForegroundWindowCommand}"
                            Padding="16,10"
                            Background="{StaticResource AccentBrush}" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            FontWeight="Bold" FontSize="14">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== 第2行：状态信息 ========== -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                <ProgressBar Width="200" Height="4"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                             IsIndeterminate="True"
                             Foreground="{StaticResource AccentBrush}"
                             Background="{StaticResource BorderBrush}"
                             Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ========== 第3行：已置顶窗口列表 ========== -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource DefaultCornerRadius}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 列表标题 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="已置顶窗口" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TopmostCount, StringFormat=' ({0})'}"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- 窗口列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding TopmostWindows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,4" Padding="8"
                                        Background="Transparent"
                                        CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 窗口信息 -->
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📌 " FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding DisplayText}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="18,2,0,0">
                                                <TextBlock Text="进程: "
                                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding ProcessName}"
                                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="  置顶时间: "
                                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                                                           Margin="8,0,0,0"/>
                                                <TextBlock Text="{Binding TopmostTime}"
                                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- 取消置顶按钮 -->
                                        <Button Grid.Column="1" Content="✕ 取消置顶"
                                                Tag="{Binding}"
                                                Click="OnRemoveTopmostClick"
                                                Padding="10,6"
                                                Background="{StaticResource DangerBrush}" Foreground="White"
                                                BorderThickness="0" Cursor="Hand" FontSize="11"
                                                VerticalAlignment="Center">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 空状态 -->
                <TextBlock Grid.Row="1" Text="暂无置顶窗口 — 点击「置顶前台窗口」将当前活动窗口置顶"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasTopmostWindows, Converter={StaticResource InvertBoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- ========== 第4行：一键取消全部 + 警告 ========== -->
        <StackPanel Grid.Row="3" Margin="0,8,0,0">
            <!-- 数量过多警告 -->
            <Border Background="{StaticResource WarningBrush}" CornerRadius="4" Padding="8,4"
                    Margin="0,0,0,6"
                    Visibility="{Binding IsTooManyWindows, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Foreground="White" FontSize="12" FontWeight="SemiBold"
                           Text="⚠ 置顶窗口超过 50 个，可能影响系统性能和稳定性，建议清理"/>
            </Border>

            <!-- 一键取消全部按钮 -->
            <Button Content="🗑 一键取消全部置顶"
                    Command="{Binding RemoveAllTopmostCommand}"
                    Padding="14,10"
                    Background="{StaticResource DangerBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    FontWeight="Bold" FontSize="14"
                    IsEnabled="{Binding HasTopmostWindows}">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
