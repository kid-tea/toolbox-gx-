<!--
    L2ConfirmDialog.xaml — L2 级别确认弹窗
    带 5 秒冷却倒计时，倒计时结束后确认按钮才可点击
    适用于不可逆操作（如禁用系统关键启动项、删除系统右键菜单项）
-->
<Window x:Class="Toolbox.Views.Dialogs.L2ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认操作" Width="450" Height="250"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Background="{StaticResource ContentBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="⚠️ 请确认此操作" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource WarningBrush}" Margin="0,0,0,12"/>

        <!-- 消息内容 -->
        <TextBlock Grid.Row="1" x:Name="MessageText" TextWrapping="Wrap" FontSize="13"
                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Top"/>

        <!-- 底部按钮区域 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Width="100" Height="32" Margin="0,0,12,0"
                    Style="{StaticResource SecondaryButtonStyle}" Click="OnCancelClick"/>
            <Button x:Name="ConfirmButton" Content="确认" Width="100" Height="32"
                    Style="{StaticResource DangerButtonStyle}" IsEnabled="False" Click="OnConfirmClick"/>
        </StackPanel>
    </Grid>
</Window>
