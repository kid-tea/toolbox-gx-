<!--
    L3ConfirmDialog.xaml — L3 级别确认弹窗
    在 L2（5秒冷却）基础上增加输入确认短语的要求
    适用于危险操作（如文件粉碎、C盘清理高级项）
-->
<Window x:Class="Toolbox.Views.Dialogs.L3ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="危险操作确认" Width="500" Height="320"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Background="{DynamicResource ContentBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="⚠️ 危险操作确认" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource DangerBrush}" Margin="0,0,0,12"/>

        <!-- 消息内容 -->
        <TextBlock Grid.Row="1" x:Name="MessageText" TextWrapping="Wrap" FontSize="13"
                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Top"/>

        <!-- 输入确认提示 -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <TextBlock x:Name="InputPromptText" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,8"/>
            <TextBox x:Name="ConfirmInput" Height="32" FontSize="14"
                     Background="{DynamicResource InputBackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     TextChanged="OnInputTextChanged"
                     Style="{DynamicResource DefaultTextBoxStyle}"/>
            <TextBlock x:Name="ErrorText" Foreground="{DynamicResource DangerBrush}" FontSize="11"
                       Visibility="Collapsed" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 底部按钮区域 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Width="100" Height="32" Margin="0,0,12,0"
                    Style="{DynamicResource SecondaryButtonStyle}" Click="OnCancelClick"/>
            <Button x:Name="ConfirmButton" Content="确认" Width="100" Height="32"
                    Style="{DynamicResource DangerButtonStyle}" IsEnabled="False" Click="OnConfirmClick"/>
        </StackPanel>
    </Grid>
</Window>
