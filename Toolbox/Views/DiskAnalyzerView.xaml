<!--
    DiskAnalyzerView.xaml — 磁盘空间分析页面
    布局：
      左侧：磁盘多选列表 + 扫描按钮
      右侧：标签页 + 树形文件夹列表 + 饼图
-->
<UserControl x:Class="Toolbox.Views.DiskAnalyzerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Toolbox.Views"
             xmlns:services="clr-namespace:Toolbox.Services"
             xmlns:viewmodels="clr-namespace:Toolbox.ViewModels"
             xmlns:converters="clr-namespace:Toolbox.Converters"
             Background="{StaticResource ContentBrush}">

    <!-- 值转换器资源 -->
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolInverseConverter x:Key="BoolInverseConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 状态/进度 -->
            <RowDefinition Height="*"/>      <!-- 主体内容 -->
            <RowDefinition Height="Auto"/>   <!-- 底部状态栏 -->
        </Grid.RowDefinitions>

        <!-- ========== 标题栏 ========== -->
        <Border Grid.Row="0" Padding="0,0,0,8">
            <StackPanel>
                <TextBlock Text="磁盘空间分析" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            </StackPanel>
        </Border>

        <!-- ========== 状态/进度 ========== -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13" TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
            <ProgressBar Value="{Binding ProgressValue}"
                         Maximum="{Binding ProgressMax}"
                         IsIndeterminate="{Binding IsProgressIndeterminate}"
                         Height="4"
                         Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}"/>
        </StackPanel>

        <!-- ========== 主体内容 ========== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <!-- 左侧：磁盘选择面板 -->
                <ColumnDefinition Width="220"/>
                <!-- 分隔 -->
                <ColumnDefinition Width="Auto"/>
                <!-- 右侧：文件夹树 + 饼图 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧磁盘选择 ===== -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4"
                    Background="{StaticResource CardBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <TextBlock Grid.Row="0" Text="选择磁盘" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="12,10,12,8"/>

                    <!-- 磁盘列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Disks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewmodels:DiskModel}">
                                    <Border Padding="12,8" Margin="0,1,0,0"
                                            Background="{StaticResource CardBrush}">
                                        <StackPanel>
                                            <!-- CheckBox + 磁盘名 -->
                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      FontSize="13" FontWeight="SemiBold"/>
                                            <!-- 标签名称 -->
                                            <TextBlock Text="{Binding Label}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11" Margin="20,0,0,2"/>
                                            <!-- 容量信息 -->
                                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                                <TextBlock Text="{Binding UsedSizeDisplay}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontSize="11"/>
                                                <TextBlock Text=" / " Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding TotalSizeDisplay}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"/>
                                            </StackPanel>
                                            <!-- 使用率进度条 -->
                                            <ProgressBar Value="{Binding UsagePercent, Mode=OneWay}" Maximum="100"
                                                         Height="4" Margin="20,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 扫描/取消按钮 -->
                    <StackPanel Grid.Row="2" Margin="12,8">
                        <Button Content="🔍 开始扫描"
                                Command="{Binding ScanCommand}"
                                Width="Auto" Height="32"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                IsEnabled="{Binding IsScanning, Converter={StaticResource BoolInverseConverter}}"/>
                        <Button Content="✖ 取消"
                                Command="{Binding CancelScanCommand}"
                                Width="Auto" Height="28" Margin="0,4,0,0"
                                Background="Transparent"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Cursor="Hand"
                                Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== 分隔条 ===== -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <!-- ===== 右侧：标签页 + 文件夹树 + 饼图 ===== -->
            <Grid Grid.Column="2" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- 标签页 -->
                    <RowDefinition Height="*"/>      <!-- 内容区 -->
                </Grid.RowDefinitions>

                <!-- 磁盘标签页（有扫描结果时才显示） -->
                <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ScannedDisks.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <ItemsControl ItemsSource="{Binding ScannedDisks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type services:DiskFolderNode}">
                                    <Border Padding="10,6" Margin="0,0,4,0"
                                            CornerRadius="4,4,0,0"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="OnDiskTabClicked">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource CardBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SizeDisplay}"
                                                       FontSize="11"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- 内容区：文件夹树 + 饼图 -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>      <!-- 文件夹树 -->
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>     <!-- 文件夹树 -->
                        <ColumnDefinition Width="Auto"/>   <!-- 分隔条 -->
                        <ColumnDefinition Width="*"/>      <!-- 饼图 -->
                    </Grid.ColumnDefinitions>

                    <!-- ===== 文件夹树 ===== -->
                    <Border Grid.Column="0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="文件夹"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="10,8"/>

                            <Grid Grid.Row="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>
                                    <TreeView ItemsSource="{Binding SafeDiskChildren}">
                                        <TreeView.Resources>
                                            <!-- 文件夹模板 -->
                                            <HierarchicalDataTemplate DataType="{x:Type services:DiskFolderNode}"
                                                                      ItemsSource="{Binding Children}">
                                                <Border Padding="4,2" Margin="0,1,0,0"
                                                        Background="Transparent"
                                                        ToolTip="{Binding FullPath}">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="📂 在资源管理器中打开"
                                                                      Click="OnOpenFolderLocation"/>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="📁"
                                                                   FontSize="13" Margin="0,0,6,0"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   Margin="8,0,8,0"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding PercentageDisplay}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   Width="45" TextAlignment="Right"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </HierarchicalDataTemplate>

                                            <!-- 单个文件模板 -->
                                            <DataTemplate DataType="{x:Type services:DiskFileItem}">
                                                <Border Padding="4,2" Margin="0,1,0,0"
                                                        Background="Transparent">
                                                    <Border.ToolTip>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding FullPath}" FontSize="11"
                                                                       Foreground="{StaticResource TextMutedBrush}"/>
                                                            <TextBlock Text="{Binding SizeDisplay}" FontSize="11"
                                                                       Foreground="{StaticResource AccentBrush}"/>
                                                        </StackPanel>
                                                    </Border.ToolTip>
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="📂 打开文件所在位置"
                                                                      Click="OnOpenFileLocation"/>
                                                            <Separator/>
                                                            <MenuItem Header="🗑️ 删除该文件"
                                                                      Click="OnDeleteFile"
                                                                      Foreground="#E74C3C"/>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="📄"
                                                                   FontSize="12" Margin="0,0,6,0"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </TreeView.Resources>
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                    </TreeView>
                                </ScrollViewer>

                                <TextBlock Text="暂无分析结果，先选择磁盘并点击左侧“开始扫描”"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDisk}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ===== 分隔条（文件夹树 ↔ 饼图） ===== -->
                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                  Background="{StaticResource BorderBrush}"
                                  Cursor="SizeWE"/>

                    <!-- ===== 饼图 ===== -->
                    <Border Grid.Column="2" Margin="4,0,0,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="空间分布"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="10,8"/>

                            <Grid Grid.Row="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding PieData}" Padding="8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type services:DiskFolderNode}">
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="60"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding SizeDisplay}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               Margin="8,0"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding PercentageDisplay}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               TextAlignment="Right"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock Text="暂无可绘制的空间分布数据"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PieData.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ========== 底部状态栏 ========== -->
        <Border Grid.Row="3" Padding="12,6"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="0,6,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</UserControl>
