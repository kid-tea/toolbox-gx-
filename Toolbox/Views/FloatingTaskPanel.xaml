<!--
    FloatingTaskPanel.xaml — 悬浮任务面板（独立 Window）
    简洁列表风格，透明度/字体/背景/大小可调，置顶开关
    独立于主窗口运行
-->
<Window x:Class="Toolbox.Views.FloatingTaskPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Toolbox.Models"
        Title="悬浮任务面板" Height="400" Width="320"
        WindowStyle="ToolWindow"
        Topmost="True"
        ShowInTaskbar="True"
        AllowsTransparency="True"
        WindowStartupLocation="Manual"
        Background="Transparent">
    <Grid>
        <Border Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="{DynamicResource DefaultCornerRadius}"
                Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- 工具栏 -->
                    <RowDefinition Height="*"/>      <!-- 任务列表 -->
                </Grid.RowDefinitions>

                <!-- 工具栏 -->
                <Border Grid.Row="0" Padding="4" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ToggleTopmostBtn" Content="📌" Width="28" Height="24"
                                Click="OnToggleTopmostClick" FontSize="12"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="悬浮任务" VerticalAlignment="Center" FontSize="12"
                                   FontWeight="SemiBold" Margin="4,0,8,0"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Button Content="✕" Width="24" Height="24"
                                Click="OnCloseClick" FontSize="11"
                                Background="Transparent"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- 任务列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="TaskItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,4" Padding="4"
                                        CornerRadius="3">
                                    <StackPanel>
                                        <!-- 内容 + 完成勾选 -->
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding IsCompleted}"
                                                      VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Content}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource CompletedBrush}"/>
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- 时间 + 重要性 -->
                                        <StackPanel Orientation="Horizontal" Margin="20,2,0,0">
                                            <TextBlock Text="{Binding NextTriggerTime, StringFormat='{}{0:MM-dd HH:mm}'}"
                                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                                            <Border Background="{DynamicResource DangerBrush}"
                                                    CornerRadius="2" Padding="2,0" Margin="6,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Importance}" Value="Normal">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="!" Foreground="White" FontSize="8" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
