<!--
    MemoryReleaseView.xaml — 内存释放功能页面
    清新现代布局：内存概览卡 + 释放操作 + 进程列表
-->
<UserControl x:Class="Toolbox.Views.MemoryReleaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Toolbox.ViewModels"
             Background="{StaticResource ContentBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== 管理员提示 ========== -->
        <Border Grid.Row="0" Background="{StaticResource WarningLightBrush}"
                CornerRadius="{StaticResource DefaultCornerRadius}" Padding="12,8"
                Margin="0,0,0,12"
                Visibility="{Binding IsAdmin, Converter={StaticResource InvertBoolToVisibilityConverter}}">
            <TextBlock Text="{Binding AdminTip}" Foreground="{StaticResource WarningBrush}" FontSize="12"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- ========== 内存概览 ========== -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource DefaultCornerRadius}" Padding="20" Margin="0,0,0,12">
            <StackPanel>
                <!-- 标题 + 刷新 -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="内存状态" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="↻ 刷新"
                            Command="{Binding RefreshMemoryInfoCommand}"
                            Style="{StaticResource SecondaryBtnStyle}"
                            Padding="10,6" FontSize="12"/>
                </Grid>

                <!-- 内存使用率进度条 -->
                <Grid Margin="0,0,0,16">
                    <ProgressBar Height="28"
                                 Maximum="100" Value="{Binding MemoryUsagePercent}"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 BorderThickness="0"/>
                    <TextBlock Text="{Binding MemoryUsagePercent, StringFormat='{}{0}%'}"
                               Foreground="White" FontSize="13" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- 内存数字概览 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource InputBackgroundBrush}"
                            CornerRadius="{StaticResource SmallCornerRadius}" Padding="12,8" Margin="0,0,6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="总量" Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalMemory}" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource DangerLightBrush}"
                            CornerRadius="{StaticResource SmallCornerRadius}" Padding="12,8" Margin="6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="已用" Foreground="{StaticResource DangerBrush}" FontSize="11"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding UsedMemory}" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource DangerBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{StaticResource SuccessLightBrush}"
                            CornerRadius="{StaticResource SmallCornerRadius}" Padding="12,8" Margin="6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="可用" Foreground="{StaticResource SuccessBrush}" FontSize="11"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding AvailableMemory}" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="{StaticResource InputBackgroundBrush}"
                            CornerRadius="{StaticResource SmallCornerRadius}" Padding="12,8" Margin="6,0,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="已缓存" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding CachedMemory}" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========== 释放操作 + 对比 ========== -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 释放按钮组 -->
            <Border Grid.Row="0" Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="{StaticResource DefaultCornerRadius}" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="🗜 清空工作集" Command="{Binding ReleaseWorkingSetCommand}"
                                IsEnabled="{Binding IsReleasing, Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="14,8" Margin="0,0,8,0"/>
                        <Button Content="🧹 清空待机列表" Command="{Binding ReleaseStandbyListCommand}"
                                IsEnabled="{Binding IsReleasing, Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource WarningButtonStyle}"
                                Padding="14,8" Margin="0,0,8,0"/>
                        <Button Content="🗄 清空系统缓存" Command="{Binding ReleaseSystemCacheCommand}"
                                IsEnabled="{Binding IsReleasing, Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource DangerButtonStyle}"
                                Padding="14,8"/>
                    </StackPanel>
                    <ProgressBar Height="4" IsIndeterminate="{Binding IsProgressIndeterminate}"
                                 Visibility="{Binding IsReleasing, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource BorderBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding ReleaseResult}"
                               Foreground="{StaticResource SuccessBrush}" FontSize="12" FontWeight="SemiBold"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- 进程列表 + 释放对比 -->
            <Border Grid.Row="1" Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="{StaticResource DefaultCornerRadius}" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- 进程列表 -->
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="内存占用排名（前10进程）" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                            <ItemsControl ItemsSource="{Binding TopProcesses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,4" Padding="8,6"
                                                Background="{StaticResource InputBackgroundBrush}"
                                                CornerRadius="{StaticResource SmallCornerRadius}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Pid, StringFormat='PID:{0}'}"
                                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding WorkingSet}"
                                                           Foreground="{StaticResource AccentBrush}" FontSize="12"
                                                           FontFamily="Consolas" VerticalAlignment="Center"
                                                           FontWeight="SemiBold" Margin="0,0,12,0"/>
                                                <TextBlock Grid.Column="3" Text="{Binding PrivateWS}"
                                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                                                           FontFamily="Consolas" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock Text="暂无进程数据，点击上方「刷新」读取"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TopProcesses.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- 释放对比 -->
                    <Border Grid.Column="1" Background="{StaticResource AccentLightBrush}"
                            CornerRadius="{StaticResource DefaultCornerRadius}" Padding="12"
                            Visibility="{Binding ShowComparison, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="释放对比" FontWeight="Bold" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="释放前" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding BeforeReleaseMemory}"
                                           Foreground="{StaticResource DangerBrush}" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock Text="↓" Foreground="{StaticResource AccentBrush}" FontSize="16"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <StackPanel>
                                <TextBlock Text="释放后" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding AfterReleaseMemory}"
                                           Foreground="{StaticResource SuccessBrush}" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== API 风险提示 ========== -->
        <Border Grid.Row="3" Background="{StaticResource WarningLightBrush}"
                CornerRadius="{StaticResource SmallCornerRadius}" Padding="10,6" Margin="0,8,0,0">
            <TextBlock Text="⚠ 风险提示：清空待机列表和系统缓存使用了非公开 Windows API，可能在系统更新后失效。请谨慎使用。"
                       Foreground="{StaticResource WarningBrush}" FontSize="11"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
