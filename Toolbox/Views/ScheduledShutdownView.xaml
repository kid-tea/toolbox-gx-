<!--
    ScheduledShutdownView.xaml — 定时关机页面
    上半部分：创建面板（模式选择、时间设置、操作选择、创建按钮）
    下半部分：任务列表（显示所有已创建任务，含状态、剩余时间）
    不支持的电源模式灰色标注，已执行任务灰色保留
-->
<UserControl x:Class="Toolbox.Views.ScheduledShutdownView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Toolbox.Views"
             xmlns:vm="clr-namespace:Toolbox.ViewModels"
             xmlns:svc="clr-namespace:Toolbox.Services"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ScheduledShutdownViewModel}"
             Background="{StaticResource ContentBrush}">

    <UserControl.Resources>
        <!-- 标准转换器 -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- 自定义转换器 -->
        <local:TaskStatusToTextConverter x:Key="StatusToTextConverter"/>
        <local:TaskStatusToColorConverter x:Key="StatusToColorConverter"/>
        <local:NegateBoolConverter x:Key="NegateBoolConverter"/>
        <local:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>

        <!-- 操作类型不可用时的文字样式 -->
        <Style x:Key="UnavailableTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>

        <!-- 创建面板区域样式 -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- ========== 状态栏 ========== -->
            <Border Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="12,8" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" FontSize="12"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- 活跃任务的剩余时间 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding HasActiveTask, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="剩余时间: " Foreground="{StaticResource TextMutedBrush}" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding RemainingTimeDisplay}"
                                   Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Button Content="取消" Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding CancelTaskCommand}" Margin="12,0,0,0"
                                Padding="10,4" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========== 创建面板 ========== -->
            <Border Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="创建定时任务" Style="{StaticResource SectionTitleStyle}"/>

                    <!-- 模式选择 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton Content="指定时间" IsChecked="{Binding IsSpecificTimeMode}"
                                     Command="{Binding SwitchToSpecificTimeCommand}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     GroupName="ShutdownMode" Margin="0,0,16,0"/>
                        <RadioButton Content="倒计时"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     GroupName="ShutdownMode"
                                     Command="{Binding SwitchToCountdownCommand}"/>
                    </StackPanel>

                    <!-- 指定时间模式的日期时间选择 -->
                    <StackPanel Visibility="{Binding IsSpecificTimeMode, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="执行日期:" Style="{StaticResource InputLabelStyle}" Width="70"/>
                            <DatePicker SelectedDate="{Binding TargetDate}"
                                        DisplayDateStart="{x:Static sys:DateTime.Today}"
                                        Background="{StaticResource InputBackgroundBrush}"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        HorizontalAlignment="Left" Width="150"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                            <TextBlock Text="执行时间:" Style="{StaticResource InputLabelStyle}" Width="70"/>
                            <TextBox Text="{Binding TargetHour, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     Width="45" TextAlignment="Center"/>
                            <TextBlock Text=" : " Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" FontSize="14"/>
                            <TextBox Text="{Binding TargetMinute, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     Width="45" TextAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 倒计时模式的时间输入 -->
                    <StackPanel Visibility="{Binding IsSpecificTimeMode, Converter={StaticResource NegateBoolConverter}}">
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                            <TextBlock Text="倒计时:" Style="{StaticResource InputLabelStyle}" Width="70"/>
                            <TextBox Text="{Binding CountdownHours, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     Width="50" TextAlignment="Center"/>
                            <TextBlock Text=" 时  " Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox Text="{Binding CountdownMinutes, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     Width="50" TextAlignment="Center"/>
                            <TextBlock Text=" 分  " Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox Text="{Binding CountdownSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     Width="50" TextAlignment="Center"/>
                            <TextBlock Text=" 秒" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 操作类型选择 -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                        <TextBlock Text="操作类型:" Style="{StaticResource InputLabelStyle}" Width="70"/>
                        <ComboBox ItemsSource="{Binding ActionItems}"
                                  SelectedValuePath="Action"
                                  SelectedValue="{Binding SelectedAction}"
                                  Width="240" HorizontalAlignment="Left"
                                  DisplayMemberPath="DisplayName"/>
                    </StackPanel>

                    <!-- 创建按钮 -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="创建任务" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CreateTaskCommand}"
                                Margin="70,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========== 任务列表 ========== -->
            <Border Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="16">
                <StackPanel>
                    <TextBlock Text="任务列表" Style="{StaticResource SectionTitleStyle}"/>

                    <!-- 无任务时的提示 -->
                    <TextBlock Text="暂无定时任务"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="12"
                               Visibility="{Binding Tasks.Count, Converter={StaticResource ZeroToVisibilityConverter}}"
                               Margin="0,8"/>

                    <!-- 任务列表视图 -->
                    <ListView ItemsSource="{Binding Tasks}"
                              Background="Transparent"
                              BorderThickness="0"
                              Visibility="{Binding Tasks.Count, Converter={StaticResource CountToVisibilityConverter}}"
                              MaxHeight="400"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.View>
                            <GridView>
                                <!-- 任务名称 -->
                                <GridViewColumn Header="任务" Width="200"
                                                DisplayMemberBinding="{Binding DisplayName}"/>

                                <!-- 操作类型 -->
                                <GridViewColumn Header="操作" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Action}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- 目标时间/倒计时 -->
                                <GridViewColumn Header="执行时间" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextPrimaryBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding TargetTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Mode}" Value="Countdown">
                                                                <Setter Property="Text" Value="{Binding Countdown, StringFormat='{}{0:hh\\:mm\\:ss}'}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- 状态 -->
                                <GridViewColumn Header="状态" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center"
                                                       Text="{Binding Status, Converter={StaticResource StatusToTextConverter}}"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- 操作按钮 -->
                                <GridViewColumn Header="" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="删除"
                                                    Padding="4,2"
                                                    FontSize="11"
                                                    Foreground="{StaticResource TextMutedBrush}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.RemoveTaskCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Pendiente">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
