<UserControl x:Class="Toolbox.Views.AgentInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Toolbox.Models"
             xmlns:converters="clr-namespace:Toolbox.Converters"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             Background="#11131A">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Toolbox;component/Resources/AgentCyberTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:BoolInverseConverter x:Key="BoolInverseConverter"/>

            <Style TargetType="{x:Type primitives:DatePickerTextBox}">
                <Setter Property="Background" Value="#202532"/>
                <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberLineBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>

            <Style x:Key="CyberDatePickerStyle" TargetType="{x:Type DatePicker}">
                <Setter Property="Background" Value="#202532"/>
                <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberLineBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>

            <Style x:Key="StatusBadgeStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="3"/>
                <Setter Property="Padding" Value="7,2"/>
                <Setter Property="Background" Value="#242A3A"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberCyanBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Level}" Value="{x:Static models:AgentFindingLevel.Attention}">
                        <Setter Property="Background" Value="#332A1A"/>
                        <Setter Property="BorderBrush" Value="{StaticResource CyberOrangeBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Level}" Value="{x:Static models:AgentFindingLevel.Risk}">
                        <Setter Property="Background" Value="#36212B"/>
                        <Setter Property="BorderBrush" Value="{StaticResource CyberMagentaBrush}"/>
                        <Setter Property="Effect" Value="{StaticResource CyberRiskGlow}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Level}" Value="{x:Static models:AgentFindingLevel.Unsupported}">
                        <Setter Property="Background" Value="#28233D"/>
                        <Setter Property="BorderBrush" Value="{StaticResource CyberPurpleBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="TokenMetricCardButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#1A1F2B"/>
                <Setter Property="BorderBrush" Value="#2E3850"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CardBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="22">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CardBorder" Property="Background" Value="#202638"/>
                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#5B72FF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="CardBorder" Property="Background" Value="#242B3A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <ControlTemplate x:Key="CyberPlotTrackerTemplate">
                <oxy:TrackerControl Position="{Binding Position}" LineExtents="{Binding LineExtents}">
                    <Border Background="#111827"
                            BorderBrush="{StaticResource CyberCyanBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,8">
                        <TextBlock Text="{Binding}"
                                   Foreground="{StaticResource CyberTextBrush}"
                                   FontFamily="Microsoft YaHei UI, Consolas"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   LineHeight="20"/>
                    </Border>
                </oxy:TrackerControl>
            </ControlTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Grid>
                        <Rectangle Fill="{StaticResource CyberBackgroundBrush}"/>
                        <Rectangle Fill="{StaticResource CyberGridBrush}" Opacity="0.7"/>
                    </Grid>
                </VisualBrush.Visual>
            </VisualBrush>
        </Grid.Background>

        <Border Background="#0011131A"/>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CyberPanelStyle}" Padding="18" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="AI Agent 检验（调试 / 2.0.0 预览）" FontSize="24"
                                   Style="{StaticResource CyberHeaderTextStyle}"
                                   Effect="{StaticResource CyberCyanGlow}"/>
                        <TextBlock Text="待优化功能：仅调试模式开放，不纳入 1.0.4 正式功能范围"
                                   Style="{StaticResource CyberMutedTextStyle}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="开始扫描"
                                Command="{Binding ScanCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource BoolInverseConverter}}"
                                Style="{StaticResource CyberButtonStyle}"
                                Margin="0,0,8,0"/>
                        <Button Content="取消"
                                Command="{Binding CancelScanCommand}"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                                Style="{StaticResource CyberGhostButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CyberPanelStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="AGENTS" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                        <TextBlock Text="{Binding DetectedAgentCountText}" FontSize="30"
                                   Style="{StaticResource CyberHeaderTextStyle}"
                                   Foreground="{StaticResource CyberCyanBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CyberPanelStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="SKILLS" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                        <TextBlock Text="{Binding SkillCountText}" FontSize="30"
                                   Style="{StaticResource CyberHeaderTextStyle}"
                                   Foreground="{StaticResource CyberGreenBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CyberPanelStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="ATTENTION" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                        <TextBlock Text="{Binding AttentionCountText}" FontSize="30"
                                   Style="{StaticResource CyberHeaderTextStyle}"
                                   Foreground="{StaticResource CyberOrangeBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource CyberPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="TOKENS" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                        <TextBlock Text="{Binding TokenAvailabilityText}" FontSize="24"
                                   Style="{StaticResource CyberHeaderTextStyle}"
                                   Foreground="{StaticResource CyberBlueBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CyberPanelStyle}" Margin="0,0,0,12" Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource CyberMutedTextStyle}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentScanTarget}"
                                   Style="{StaticResource CyberMutedTextStyle}"
                                   Foreground="{StaticResource CyberCyanBrush}"/>
                    </Grid>
                    <ProgressBar Value="{Binding ProgressValue}"
                                 Maximum="{Binding ProgressMax}"
                                 IsIndeterminate="{Binding IsProgressIndeterminate}"
                                 Style="{StaticResource CyberProgressBarStyle}"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <TabControl Grid.Row="3"
                        Style="{StaticResource CyberTabControlStyle}"
                        ItemContainerStyle="{StaticResource CyberTabItemStyle}">
                <TabItem Header="环境概览">
                    <Border Style="{StaticResource CyberPanelStyle}" Margin="0,8,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Environments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#2C3344" BorderThickness="0,0,0,1" Padding="0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource CyberHeaderTextStyle}" FontSize="14"/>
                                                <Border Grid.Column="1" Style="{StaticResource StatusBadgeStyle}" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Level}" Foreground="{StaticResource CyberTextBrush}" FontSize="11" FontFamily="Consolas"/>
                                                </Border>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource CyberTextBrush}" FontFamily="Consolas"/>
                                                    <TextBlock Text="{Binding Detail}" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <TabItem Header="Skills / 规则">
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CyberPanelStyle}">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="SKILL TREE" Style="{StaticResource CyberHeaderTextStyle}" FontSize="18"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding SkillDescriptionLanguages}"
                                              SelectedItem="{Binding SelectedSkillDescriptionLanguage, Mode=TwoWay}"
                                              MinWidth="96"
                                              Style="{StaticResource CyberComboBoxStyle}"/>
                                </Grid>

                                <TreeView ItemsSource="{Binding SkillAgentGroups}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Foreground="{StaticResource CyberTextBrush}"
                                          FontFamily="Consolas">
                                    <TreeView.Resources>
                                        <HierarchicalDataTemplate DataType="{x:Type models:AgentSkillAgentGroup}" ItemsSource="{Binding PluginGroups}">
                                            <Border Background="#242A3A" BorderBrush="#343B4D" BorderThickness="1" CornerRadius="6" Padding="8,5" Margin="0,4,0,4">
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource CyberCyanBrush}" FontSize="16" FontWeight="Bold"/>
                                            </Border>
                                        </HierarchicalDataTemplate>

                                        <HierarchicalDataTemplate DataType="{x:Type models:AgentSkillPluginGroup}" ItemsSource="{Binding Skills}">
                                            <Border Background="#202E2D" BorderBrush="#2F4540" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,3,0,3">
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource CyberGreenBrush}" FontSize="15" FontWeight="SemiBold"/>
                                            </Border>
                                        </HierarchicalDataTemplate>

                                        <DataTemplate DataType="{x:Type models:AgentSkillItem}">
                                            <Border BorderBrush="#2C3344" BorderThickness="0,0,0,1" Padding="8,8" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0"
                                                               Text="{Binding Name}"
                                                               Foreground="{StaticResource CyberTextBrush}"
                                                               FontFamily="Consolas"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding Description}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource CyberMutedBrush}"
                                                               FontFamily="Consolas"
                                                               FontSize="14"
                                                               Margin="0,5,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUserEditable}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <Grid Grid.Row="2" Margin="0,6,0,0">
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUserEditable}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 MinHeight="54"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 Background="#202532"
                                                                 Foreground="{StaticResource CyberTextBrush}"
                                                                 BorderBrush="{StaticResource CyberLineBrush}"
                                                                 FontFamily="Consolas"
                                                                 FontSize="14"
                                                                 Padding="8,5"/>
                                                        <Button Grid.Column="1"
                                                                Content="保存说明"
                                                                Command="{Binding DataContext.SaveSkillDescriptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource CyberGhostButtonStyle}"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Top"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </TreeView.Resources>
                                </TreeView>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CyberPanelStyle}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="PROJECT RULES" Style="{StaticResource CyberHeaderTextStyle}" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding ProjectRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#2C3344" BorderThickness="0,0,0,1" Padding="0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource CyberTextBrush}" FontFamily="Consolas"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Detail}" Style="{StaticResource CyberMutedTextStyle}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Token 消耗">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,12">
                            <Button Style="{StaticResource TokenMetricCardButtonStyle}"
                                    Command="{Binding SelectTokenPeriodCommand}"
                                    CommandParameter="TODAY"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="今日" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Text="{Binding TodayTokensText}" ToolTip="{Binding TokenSummary.TodayTokens, StringFormat={}{0:N0} 原始 Token}" FontSize="22" Foreground="{StaticResource CyberCyanBrush}" Style="{StaticResource CyberHeaderTextStyle}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource TokenMetricCardButtonStyle}"
                                    Command="{Binding SelectTokenPeriodCommand}"
                                    CommandParameter="WEEK"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="本周" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Text="{Binding WeekTokensText}" ToolTip="{Binding TokenSummary.ThisWeekTokens, StringFormat={}{0:N0} 原始 Token}" FontSize="22" Foreground="{StaticResource CyberBlueBrush}" Style="{StaticResource CyberHeaderTextStyle}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource TokenMetricCardButtonStyle}"
                                    Command="{Binding SelectTokenPeriodCommand}"
                                    CommandParameter="MONTH"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="本月" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Text="{Binding MonthTokensText}" ToolTip="{Binding TokenSummary.ThisMonthTokens, StringFormat={}{0:N0} 原始 Token}" FontSize="22" Foreground="{StaticResource CyberGreenBrush}" Style="{StaticResource CyberHeaderTextStyle}"/>
                                </StackPanel>
                            </Button>
                            <Border Style="{StaticResource CyberPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="估算费用" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Text="{Binding EstimatedCostText}" FontSize="20" Foreground="{StaticResource CyberOrangeBrush}" Style="{StaticResource CyberHeaderTextStyle}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="1" Style="{StaticResource CyberPanelStyle}" Margin="0,0,0,12" Padding="14">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding SelectedTokenPeriodTitle}" Style="{StaticResource CyberHeaderTextStyle}" FontSize="16"/>
                                    <TextBlock Grid.Column="1" Text="缓存命中率 = cached input / input" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                                </Grid>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="软件" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Grid.Column="1" Text="模型" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Grid.Column="2" Text="消耗" Style="{StaticResource CyberMutedTextStyle}" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="调用次数" Style="{StaticResource CyberMutedTextStyle}" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="缓存命中率" Style="{StaticResource CyberMutedTextStyle}" HorizontalAlignment="Right"/>
                                </Grid>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="155">
                                    <ItemsControl ItemsSource="{Binding TokenModelSummaries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#2C3344" BorderThickness="0,0,0,1" Padding="0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="90"/>
                                                            <ColumnDefinition Width="130"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Agent}" Foreground="{StaticResource CyberTextBrush}" FontFamily="Consolas"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Model}" Style="{StaticResource CyberMutedTextStyle}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding TokensText}" Foreground="{StaticResource CyberCyanBrush}" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding CallCountText}" Foreground="{StaticResource CyberMutedBrush}" FontFamily="Microsoft YaHei UI, Consolas" HorizontalAlignment="Right"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding CacheHitRateText}" Foreground="{StaticResource CyberOrangeBrush}" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CyberPanelStyle}" Margin="0,0,0,12" Padding="12">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="DATE" Style="{StaticResource CyberMutedTextStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding TokenScopeNote}" Style="{StaticResource CyberMutedTextStyle}" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding SelectedTokenDateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Width="150"
                                             VerticalAlignment="Center"
                                             Background="#202532"
                                             Foreground="{StaticResource CyberTextBrush}"
                                             BorderBrush="{StaticResource CyberLineBrush}"
                                             BorderThickness="1"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             Padding="8,5"/>
                                    <Button Grid.Column="2"
                                            Content="今天"
                                            Command="{Binding ShowTodayTokensCommand}"
                                            Style="{StaticResource CyberGhostButtonStyle}"
                                            HorizontalAlignment="Left"
                                            Margin="8,0,0,0"/>

                                    <StackPanel Grid.Column="3" Margin="20,0,0,0">
                                        <TextBlock Text="{Binding SelectedTokenDateLabel}" Style="{StaticResource CyberMutedTextStyle}"/>
                                        <TextBlock Text="{Binding SelectedDayTotalTokensText}" Foreground="{StaticResource CyberCyanBrush}" FontSize="18" FontFamily="Consolas" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" Margin="20,0,0,0">
                                        <TextBlock Text="调用次数" Style="{StaticResource CyberMutedTextStyle}"/>
                                        <TextBlock Text="{Binding SelectedDayCallCountText}" Foreground="{StaticResource CyberMutedBrush}" FontSize="15" FontFamily="Microsoft YaHei UI, Consolas" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="5" Margin="20,0,0,0">
                                        <TextBlock Text="CACHE HIT" Style="{StaticResource CyberMutedTextStyle}"/>
                                        <TextBlock Text="{Binding SelectedDayCacheHitRateText}" Foreground="{StaticResource CyberOrangeBrush}" FontSize="18" FontFamily="Consolas" FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>

                                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding SelectedDayHistoryStatusText}" Style="{StaticResource CyberMutedTextStyle}" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="单日总消耗 / 最近 30 天历史" Style="{StaticResource CyberMutedTextStyle}" FontSize="12"/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding SelectedDayTokenModelSummaries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#2C3344" BorderThickness="0,0,0,1" Padding="0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Agent}" Foreground="{StaticResource CyberTextBrush}" FontFamily="Consolas"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Model}" Style="{StaticResource CyberMutedTextStyle}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding TokensText}" Foreground="{StaticResource CyberCyanBrush}" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding CallCountText}" Foreground="{StaticResource CyberMutedBrush}" FontFamily="Microsoft YaHei UI, Consolas" HorizontalAlignment="Right"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding CacheHitRateText}" Foreground="{StaticResource CyberOrangeBrush}" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>

                        <TabControl Grid.Row="3"
                                    Style="{StaticResource CyberTabControlStyle}"
                                    ItemContainerStyle="{StaticResource CyberTabItemStyle}">
                            <TabItem Header="消耗趋势">
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CyberPanelStyle}" Padding="8">
                                        <oxy:PlotView Model="{Binding TokenTrendPlot}"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      DefaultTrackerTemplate="{StaticResource CyberPlotTrackerTemplate}"/>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource CyberPanelStyle}" Padding="8">
                                        <oxy:PlotView Model="{Binding ModelCallTrendPlot}"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      DefaultTrackerTemplate="{StaticResource CyberPlotTrackerTemplate}"/>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Header="单次消耗明细">
                                <Border Style="{StaticResource CyberPanelStyle}" Margin="0,8,0,0" Padding="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="170"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="AGENT" Style="{StaticResource CyberMutedTextStyle}"/>
                                            <TextBlock Grid.Column="1" Text="TIME DESC" Style="{StaticResource CyberMutedTextStyle}"/>
                                            <TextBlock Grid.Column="2" Text="MODEL" Style="{StaticResource CyberMutedTextStyle}"/>
                                            <TextBlock Grid.Column="3" Text="RAW TOKENS" Style="{StaticResource CyberMutedTextStyle}" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding SelectedDateTokenRecords}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#2C3344" BorderThickness="0,0,0,1" Padding="0,10">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="130"/>
                                                                    <ColumnDefinition Width="170"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="150"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Agent}" Style="{StaticResource CyberMutedTextStyle}"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Date, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Foreground="{StaticResource CyberTextBrush}" FontFamily="Consolas"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding Model}" Style="{StaticResource CyberMutedTextStyle}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="3" Text="{Binding Tokens, StringFormat={}{0:N0}}" Foreground="{StaticResource CyberCyanBrush}" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <TabItem Header="报告">
                    <Border Style="{StaticResource CyberPanelStyle}" Margin="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="复制 Markdown" Command="{Binding CopyReportCommand}" Style="{StaticResource CyberButtonStyle}" Margin="0,0,8,0"/>
                                <Button Content="保存报告" Command="{Binding SaveReportCommand}" Style="{StaticResource CyberGhostButtonStyle}"/>
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     Text="{Binding ReportText}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#202532"
                                     Foreground="{StaticResource CyberTextBrush}"
                                     BorderBrush="{StaticResource CyberLineBrush}"
                                     FontFamily="Consolas"
                                     FontSize="12"/>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
