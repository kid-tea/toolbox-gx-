<UserControl x:Class="Toolbox.Views.AgentInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Toolbox.Models"
             xmlns:converters="clr-namespace:Toolbox.Converters"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             Background="{DynamicResource ContentBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:BoolInverseConverter x:Key="BoolInverseConverter"/>

            <Style TargetType="{x:Type primitives:DatePickerTextBox}">
                <Setter Property="Background" Value="{StaticResource CyberInputBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberLineBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>

            <Style TargetType="{x:Type CalendarDayButton}">
                <Setter Property="Background" Value="{StaticResource CyberPanelBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberLineBrush}"/>
                <Setter Property="FontFamily" Value="Consolas"/>
            </Style>

            <Style TargetType="{x:Type CalendarButton}">
                <Setter Property="Background" Value="{StaticResource CyberPanelBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberLineBrush}"/>
                <Setter Property="FontFamily" Value="Consolas"/>
            </Style>

            <Style x:Key="TokenConversationExpanderStyle" TargetType="{x:Type Expander}">
                <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberLineBrush}"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI, Consolas"/>
            </Style>

            <Style x:Key="CyberDatePickerStyle" TargetType="{x:Type DatePicker}">
                <Setter Property="Height" Value="38"/>
                <Setter Property="Background" Value="{StaticResource CyberInputBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberLineBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type DatePicker}">
                            <Grid SnapsToDevicePixels="True">
                                <Border x:Name="DatePickerBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>

                                        <primitives:DatePickerTextBox x:Name="PART_TextBox"
                                                                      Grid.Column="0"
                                                                      Background="Transparent"
                                                                      Foreground="{TemplateBinding Foreground}"
                                                                      BorderThickness="0"
                                                                      Padding="10,0,4,0"
                                                                      VerticalContentAlignment="Center"/>

                                        <Button x:Name="PART_Button"
                                                Grid.Column="1"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Focusable="False">
                                            <Grid Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Stroke="{StaticResource CyberCyanBrush}"
                                                      StrokeThickness="1.55"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Data="M 3 4.5 L 15 4.5 L 15 15 L 3 15 Z M 3 7.5 L 15 7.5 M 6 2.5 L 6 5.5 M 12 2.5 L 12 5.5"/>
                                                <Path Fill="{StaticResource CyberCyanBrush}"
                                                      Data="M 5 9 L 7 9 L 7 11 L 5 11 Z M 8 9 L 10 9 L 10 11 L 8 11 Z M 11 9 L 13 9 L 13 11 L 11 11 Z M 5 12 L 7 12 L 7 14 L 5 14 Z M 8 12 L 10 12 L 10 14 L 8 14 Z"/>
                                            </Grid>
                                        </Button>
                                    </Grid>
                                </Border>

                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=DatePickerBorder}"
                                       StaysOpen="False"
                                       PopupAnimation="Fade">
                                    <Border Background="{StaticResource CyberPanelBrush}"
                                            BorderBrush="{StaticResource CyberLineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8">
                                        <Calendar x:Name="PART_Calendar"
                                                  Background="{StaticResource CyberPanelBrush}"
                                                  Foreground="{StaticResource CyberTextBrush}"
                                                  BorderThickness="0"
                                                  SelectedDate="{Binding SelectedDate, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  DisplayDate="{Binding DisplayDate, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  DisplayDateStart="{Binding DisplayDateStart, RelativeSource={RelativeSource TemplatedParent}}"
                                                  DisplayDateEnd="{Binding DisplayDateEnd, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="DatePickerBorder" Property="BorderBrush" Value="{StaticResource CyberFocusBrush}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="DatePickerBorder" Property="BorderBrush" Value="{StaticResource CyberFocusBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="DatePickerBorder" Property="Opacity" Value="0.55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="StatusBadgeStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="3"/>
                <Setter Property="Padding" Value="7,2"/>
                <Setter Property="Background" Value="{StaticResource CyberHoverBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberCyanBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Level}" Value="{x:Static models:AgentFindingLevel.Attention}">
                        <Setter Property="Background" Value="{StaticResource CyberAttentionBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource CyberOrangeBrush}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Level}" Value="{x:Static models:AgentFindingLevel.Risk}">
                        <Setter Property="Background" Value="{StaticResource CyberRiskPanelBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource CyberMagentaBrush}"/>
                        <Setter Property="Effect" Value="{StaticResource CyberRiskGlow}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Level}" Value="{x:Static models:AgentFindingLevel.Unsupported}">
                        <Setter Property="Background" Value="{StaticResource CyberUnsupportedBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource CyberPurpleBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="TokenMetricCardButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource CyberMetricCardBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyberLineBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="{StaticResource CyberTextBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CardBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="22">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource CyberMetricCardHoverBrush}"/>
                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource CyberFocusBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource CyberMetricCardPressedBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <ControlTemplate x:Key="CyberPlotTrackerTemplate">
                <oxy:TrackerControl Position="{Binding Position}" LineExtents="{Binding LineExtents}">
                    <Border Background="{StaticResource CyberTrackerBrush}"
                            BorderBrush="{StaticResource CyberCyanBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,8">
                        <TextBlock Text="{Binding}"
                                   Foreground="{StaticResource CyberTextBrush}"
                                   FontFamily="Microsoft YaHei UI, Consolas"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   LineHeight="20"/>
                    </Border>
                </oxy:TrackerControl>
            </ControlTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Grid>
                        <Rectangle Fill="{StaticResource CyberBackgroundBrush}"/>
                        <Rectangle Fill="{StaticResource CyberGridBrush}" Opacity="0.18"/>
                    </Grid>
                </VisualBrush.Visual>
            </VisualBrush>
        </Grid.Background>

        <Border Background="#0011131A"/>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CyberPanelStyle}" Padding="18" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="AI Agent 检验（调试 / 2.0.0 预览）" FontSize="24"
                                   Style="{StaticResource CyberHeaderTextStyle}"
                                   Effect="{StaticResource CyberCyanGlow}"/>
                        <TextBlock Text="待优化功能：仅调试模式开放，不纳入 1.0.4 正式功能范围"
                                   Style="{StaticResource CyberMutedTextStyle}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="开始扫描"
                                Command="{Binding ScanCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource BoolInverseConverter}}"
                                Style="{StaticResource CyberButtonStyle}"
                                Margin="0,0,8,0"/>
                        <Button Content="取消"
                                Command="{Binding CancelScanCommand}"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                                Style="{StaticResource CyberGhostButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CyberPanelStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="AGENTS" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                        <TextBlock Text="{Binding DetectedAgentCountText}" FontSize="30"
                                   Style="{StaticResource CyberHeaderTextStyle}"
                                   Foreground="{StaticResource CyberCyanBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CyberPanelStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="SKILLS" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                        <TextBlock Text="{Binding SkillCountText}" FontSize="30"
                                   Style="{StaticResource CyberHeaderTextStyle}"
                                   Foreground="{StaticResource CyberGreenBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CyberPanelStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="ATTENTION" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                        <TextBlock Text="{Binding AttentionCountText}" FontSize="30"
                                   Style="{StaticResource CyberHeaderTextStyle}"
                                   Foreground="{StaticResource CyberOrangeBrush}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource CyberPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="TOKENS" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                        <TextBlock Text="{Binding TokenAvailabilityText}" FontSize="24"
                                   Style="{StaticResource CyberHeaderTextStyle}"
                                   Foreground="{StaticResource CyberBlueBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CyberPanelStyle}" Margin="0,0,0,12" Padding="12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource CyberMutedTextStyle}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentScanTarget}"
                                   Style="{StaticResource CyberMutedTextStyle}"
                                   Foreground="{StaticResource CyberCyanBrush}"/>
                    </Grid>
                    <ProgressBar Value="{Binding ProgressValue}"
                                 Maximum="{Binding ProgressMax}"
                                 IsIndeterminate="{Binding IsProgressIndeterminate}"
                                 Style="{StaticResource CyberProgressBarStyle}"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <TabControl Grid.Row="3"
                        Style="{StaticResource CyberTabControlStyle}"
                        ItemContainerStyle="{StaticResource CyberTabItemStyle}">
                <TabItem Header="&#x73AF;&#x5883;&#x6982;&#x89C8;">
                    <Border Style="{StaticResource CyberPanelStyle}" Margin="0,8,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Environments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource CyberLineBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource CyberHeaderTextStyle}" FontSize="14"/>
                                                <Border Grid.Column="1" Style="{StaticResource StatusBadgeStyle}" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Level}" Foreground="{StaticResource CyberTextBrush}" FontSize="11" FontFamily="Consolas"/>
                                                </Border>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource CyberTextBrush}" FontFamily="Consolas"/>
                                                    <TextBlock Text="{Binding Detail}" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <TabItem Header="Skills / &#x89C4;&#x5219;">
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*" MinWidth="320"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*" MinWidth="260"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CyberPanelStyle}">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Skill &#x5206;&#x7EC4;" Style="{StaticResource CyberHeaderTextStyle}" FontSize="18"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding SkillDescriptionLanguages}"
                                              SelectedItem="{Binding SelectedSkillDescriptionLanguage, Mode=TwoWay}"
                                              MinWidth="96"
                                              Style="{StaticResource CyberComboBoxStyle}"/>
                                </Grid>

                                <TreeView ItemsSource="{Binding SkillAgentGroups}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Foreground="{StaticResource CyberTextBrush}"
                                          FontFamily="Microsoft YaHei UI, Segoe UI, Consolas"
                                          ItemContainerStyle="{StaticResource CyberTreeViewItemStyle}">
                                    <TreeView.Resources>
                                        <Style TargetType="{x:Type TreeViewItem}" BasedOn="{StaticResource CyberTreeViewItemStyle}"/>

                                        <HierarchicalDataTemplate DataType="{x:Type models:AgentSkillAgentGroup}" ItemsSource="{Binding PluginGroups}">
                                            <Border Background="Transparent" BorderBrush="{StaticResource CyberLineBrush}" BorderThickness="0,0,0,1" Padding="8,7" Margin="0,2,0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="8" Height="8" Fill="{StaticResource CyberCyanBrush}" Opacity="0.85" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="{StaticResource CyberCyanBrush}" FontSize="17" FontWeight="Bold" Margin="6,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </HierarchicalDataTemplate>

                                        <HierarchicalDataTemplate DataType="{x:Type models:AgentSkillPluginGroup}" ItemsSource="{Binding Skills}">
                                            <Border Background="Transparent" BorderBrush="{StaticResource CyberLineBrush}" BorderThickness="0,0,0,1" Padding="8,6" Margin="0,1,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="7" Height="7" Fill="{StaticResource CyberGreenBrush}" Opacity="0.78" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="{StaticResource CyberGreenBrush}" FontSize="16" FontWeight="SemiBold" Margin="6,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </HierarchicalDataTemplate>

                                        <DataTemplate DataType="{x:Type models:AgentSkillItem}">
                                            <Border BorderBrush="{StaticResource CyberLineBrush}" BorderThickness="0,0,0,1" Padding="8,8" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0"
                                                               Text="{Binding Name}"
                                                               Foreground="{StaticResource CyberTextBrush}"
                                                               FontFamily="Consolas"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding Description}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource CyberMutedBrush}"
                                                               FontFamily="Consolas"
                                                               FontSize="14"
                                                               Margin="0,5,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUserEditable}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <Grid Grid.Row="2" Margin="0,6,0,0">
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUserEditable}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 MinHeight="54"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="True"
                                                                 Style="{StaticResource CyberTextBoxStyle}"/>
                                                        <Button Grid.Column="1"
                                                                Content="&#x4FDD;&#x5B58;&#x8BF4;&#x660E;"
                                                                Command="{Binding DataContext.SaveSkillDescriptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource CyberGhostButtonStyle}"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Top"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </TreeView.Resources>
                                </TreeView>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CyberPanelStyle}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="&#x9879;&#x76EE;&#x89C4;&#x5219;" Style="{StaticResource CyberHeaderTextStyle}" FontSize="18" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding ProjectRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource CyberLineBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource CyberTextBrush}" FontFamily="Consolas"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Detail}" Style="{StaticResource CyberMutedTextStyle}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Token &#x6D88;&#x8017;">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,12">
                            <Button Style="{StaticResource TokenMetricCardButtonStyle}"
                                    Command="{Binding SelectTokenPeriodCommand}"
                                    CommandParameter="TODAY"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="&#x4ECA;&#x65E5;" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Text="{Binding TodayTokensText}" ToolTip="{Binding TokenSummary.TodayTokens, StringFormat={}{0:N0} &#x539F;&#x59CB; Token}" FontSize="22" Foreground="{StaticResource CyberCyanBrush}" Style="{StaticResource CyberHeaderTextStyle}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource TokenMetricCardButtonStyle}"
                                    Command="{Binding SelectTokenPeriodCommand}"
                                    CommandParameter="WEEK"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="&#x672C;&#x5468;" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Text="{Binding WeekTokensText}" ToolTip="{Binding TokenSummary.ThisWeekTokens, StringFormat={}{0:N0} &#x539F;&#x59CB; Token}" FontSize="22" Foreground="{StaticResource CyberBlueBrush}" Style="{StaticResource CyberHeaderTextStyle}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource TokenMetricCardButtonStyle}"
                                    Command="{Binding SelectTokenPeriodCommand}"
                                    CommandParameter="MONTH"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="&#x672C;&#x6708;" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Text="{Binding MonthTokensText}" ToolTip="{Binding TokenSummary.ThisMonthTokens, StringFormat={}{0:N0} &#x539F;&#x59CB; Token}" FontSize="22" Foreground="{StaticResource CyberGreenBrush}" Style="{StaticResource CyberHeaderTextStyle}"/>
                                </StackPanel>
                            </Button>
                            <Border Style="{StaticResource CyberPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="&#x4F30;&#x7B97;&#x8D39;&#x7528;" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Text="{Binding EstimatedCostText}" FontSize="20" Foreground="{StaticResource CyberOrangeBrush}" Style="{StaticResource CyberHeaderTextStyle}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="1" Style="{StaticResource CyberPanelStyle}" Margin="0,0,0,12" Padding="14">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding SelectedTokenPeriodTitle}" Style="{StaticResource CyberHeaderTextStyle}" FontSize="16"/>
                                    <TextBlock Grid.Column="1" Text="&#x7F13;&#x5B58;&#x547D;&#x4E2D;&#x7387; = cached input / input" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                                </Grid>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="112"/>
                                        <ColumnDefinition Width="84"/>
                                        <ColumnDefinition Width="112"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#x8F6F;&#x4EF6;" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Grid.Column="1" Text="&#x6A21;&#x578B;" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Grid.Column="2" Text="&#x6D88;&#x8017;" Style="{StaticResource CyberMutedTextStyle}" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="&#x8C03;&#x7528;&#x6B21;&#x6570;" Style="{StaticResource CyberMutedTextStyle}" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="&#x7F13;&#x5B58;&#x547D;&#x4E2D;&#x7387;" Style="{StaticResource CyberMutedTextStyle}" HorizontalAlignment="Right"/>
                                </Grid>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="155">
                                    <ItemsControl ItemsSource="{Binding TokenModelSummaries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource CyberLineBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="96"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="112"/>
                                                            <ColumnDefinition Width="84"/>
                                                            <ColumnDefinition Width="112"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Agent}" Foreground="{StaticResource CyberTextBrush}" FontFamily="Consolas"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Model}" Style="{StaticResource CyberMutedTextStyle}" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding TokensText}" Foreground="{StaticResource CyberCyanBrush}" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding CallCountText}" Foreground="{StaticResource CyberMutedBrush}" FontFamily="Microsoft YaHei UI, Consolas" HorizontalAlignment="Right"/>
                                                        <TextBlock Grid.Column="4" Text="{Binding CacheHitRateText}" Foreground="{StaticResource CyberOrangeBrush}" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CyberPanelStyle}" Margin="0,0,0,12" Padding="12">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="&#x65E5;&#x671F;" Style="{StaticResource CyberMutedTextStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding TokenScopeNote}" Style="{StaticResource CyberMutedTextStyle}" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <DatePicker Grid.Column="1"
                                                SelectedDate="{Binding SelectedTokenDate, Mode=TwoWay}"
                                                Width="162"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource CyberDatePickerStyle}"/>
                                    <Button Grid.Column="2"
                                            Content="&#x4ECA;&#x5929;"
                                            Command="{Binding ShowTodayTokensCommand}"
                                            Style="{StaticResource CyberGhostButtonStyle}"
                                            HorizontalAlignment="Left"
                                            Margin="8,0,0,0"/>

                                    <StackPanel Grid.Column="3" Margin="20,0,0,0">
                                        <TextBlock Text="{Binding SelectedTokenDateLabel}" Style="{StaticResource CyberMutedTextStyle}"/>
                                        <TextBlock Text="{Binding SelectedDayTotalTokensText}" Foreground="{StaticResource CyberCyanBrush}" FontSize="18" FontFamily="Consolas" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" Margin="20,0,0,0">
                                        <TextBlock Text="&#x8C03;&#x7528;&#x6B21;&#x6570;" Style="{StaticResource CyberMutedTextStyle}"/>
                                        <TextBlock Text="{Binding SelectedDayCallCountText}" Foreground="{StaticResource CyberMutedBrush}" FontSize="15" FontFamily="Microsoft YaHei UI, Consolas" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="5" Margin="20,0,0,0">
                                        <TextBlock Text="&#x7F13;&#x5B58;&#x547D;&#x4E2D;&#x7387;" Style="{StaticResource CyberMutedTextStyle}"/>
                                        <TextBlock Text="{Binding SelectedDayCacheHitRateText}" Foreground="{StaticResource CyberOrangeBrush}" FontSize="18" FontFamily="Consolas" FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>

                                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding SelectedDayHistoryStatusText}" Style="{StaticResource CyberMutedTextStyle}" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="&#x5355;&#x65E5;&#x603B;&#x6D88;&#x8017; / &#x6700;&#x8FD1; 30 &#x5929;&#x5386;&#x53F2;" Style="{StaticResource CyberMutedTextStyle}" FontSize="12"/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding SelectedDayTokenModelSummaries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource CyberLineBrush}" BorderThickness="0,0,0,1" Padding="0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="96"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="112"/>
                                                        <ColumnDefinition Width="84"/>
                                                        <ColumnDefinition Width="112"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Agent}" Foreground="{StaticResource CyberTextBrush}" FontFamily="Consolas"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Model}" Style="{StaticResource CyberMutedTextStyle}" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding TokensText}" Foreground="{StaticResource CyberCyanBrush}" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding CallCountText}" Foreground="{StaticResource CyberMutedBrush}" FontFamily="Microsoft YaHei UI, Consolas" HorizontalAlignment="Right"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding CacheHitRateText}" Foreground="{StaticResource CyberOrangeBrush}" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="3" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CyberPanelStyle}" Padding="8">
                                <oxy:PlotView Model="{Binding TokenTrendPlot}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              DefaultTrackerTemplate="{StaticResource CyberPlotTrackerTemplate}"/>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CyberPanelStyle}" Padding="8">
                                <oxy:PlotView Model="{Binding ModelCallTrendPlot}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              DefaultTrackerTemplate="{StaticResource CyberPlotTrackerTemplate}"/>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="对话 Token 明细">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CyberPanelStyle}" Margin="0,0,0,12" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="日期" Style="{StaticResource CyberMutedTextStyle}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <DatePicker Grid.Column="1"
                                            SelectedDate="{Binding SelectedTokenDate, Mode=TwoWay}"
                                            Width="162"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CyberDatePickerStyle}"/>
                                <Button Grid.Column="2"
                                        Content="今天"
                                        Command="{Binding ShowTodayTokensCommand}"
                                        Style="{StaticResource CyberGhostButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Margin="8,0,0,0"/>

                                <StackPanel Grid.Column="3" Margin="20,0,0,0">
                                    <TextBlock Text="选中日期" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Text="{Binding SelectedTokenDateLabel}" Foreground="{StaticResource CyberTextBrush}" FontFamily="Consolas" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4" Margin="20,0,0,0">
                                    <TextBlock Text="总 Token" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Text="{Binding SelectedDateTokensText}" Foreground="{StaticResource CyberCyanBrush}" FontSize="18" FontFamily="Consolas" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="5" Margin="20,0,0,0">
                                    <TextBlock Text="请求数 / 模型" Style="{StaticResource CyberMutedTextStyle}"/>
                                    <TextBlock Foreground="{StaticResource CyberMutedBrush}" FontFamily="Microsoft YaHei UI, Consolas" FontWeight="SemiBold">
                                        <Run Text="{Binding SelectedDateCallCountText}"/>
                                        <Run Text=" 次 / "/>
                                        <Run Text="{Binding SelectedDateModelCountText}"/>
                                        <Run Text=" 个"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CyberPanelStyle}" Margin="0,0,0,12" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="对话默认折叠，只展示单条对话 Token 消耗；展开后查看 Input / Cache / Output / Reasoning 明细。"
                                               Foreground="{StaticResource CyberTextBrush}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="日期过滤使用本地日期，并会跳过疑似 Codex 历史快照回放，避免把旧对话算进今天。"
                                               Style="{StaticResource CyberMutedTextStyle}"
                                               FontSize="12"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="点击每条对话左侧箭头展开"
                                           Style="{StaticResource CyberMutedTextStyle}"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CyberPanelStyle}" Padding="0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SelectedDateTokenConversations}" Margin="14,4,14,14">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource CyberLineBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                                <Expander Style="{StaticResource TokenConversationExpanderStyle}" IsExpanded="False">
                                                    <Expander.Header>
                                                        <Grid MinHeight="68"
                                                              Margin="0,0,30,0"
                                                              HorizontalAlignment="Stretch">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                                                <TextBlock Text="&#x5BF9;&#x8BDD;" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                                                                <TextBlock Text="{Binding ConversationTitle}" Foreground="{StaticResource CyberTextBrush}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                                                        Width="170"
                                                                        MaxWidth="170"
                                                                        VerticalAlignment="Center"
                                                                        HorizontalAlignment="Right">
                                                                <TextBlock Text="&#x5BF9;&#x8BDD;&#x603B;&#x7528;&#x91CF;"
                                                                           Style="{StaticResource CyberMutedTextStyle}"
                                                                           FontSize="11"
                                                                           HorizontalAlignment="Right"
                                                                           TextAlignment="Right"
                                                                           TextWrapping="Wrap"/>
                                                                <TextBlock HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="NoWrap">
                                                                    <Run Text="{Binding TokensText}" Foreground="{StaticResource CyberCyanBrush}" FontFamily="Consolas" FontSize="18" FontWeight="Bold"/>
                                                                    <Run Text=" Token" Foreground="{StaticResource CyberCyanBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                                </TextBlock>
                                                            </StackPanel>

                                                            <WrapPanel Grid.Row="1" Grid.Column="0"
                                                                       Margin="0,8,16,0"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock Margin="0,0,16,4" Foreground="{StaticResource CyberMutedBrush}" FontSize="12">
                                                                    <Run Text="&#x8F6F;&#x4EF6; "/>
                                                                    <Run Text="{Binding Agent}" FontFamily="Consolas" FontWeight="SemiBold" Foreground="{StaticResource CyberTextBrush}"/>
                                                                </TextBlock>
                                                                <TextBlock Margin="0,0,16,4" Foreground="{StaticResource CyberMutedBrush}" FontSize="12">
                                                                    <Run Text="&#x5F00;&#x59CB; "/>
                                                                    <Run Text="{Binding Date, StringFormat={}{0:yyyy-MM-dd HH:mm}}" FontFamily="Consolas" FontWeight="SemiBold" Foreground="{StaticResource CyberTextBrush}"/>
                                                                </TextBlock>
                                                                <TextBlock Margin="0,0,16,4" Foreground="{StaticResource CyberMutedBrush}" FontSize="12">
                                                                    <Run Text="&#x6A21;&#x578B; "/>
                                                                    <Run Text="{Binding Model}" Foreground="{StaticResource CyberTextBrush}"/>
                                                                </TextBlock>
                                                                <TextBlock Margin="0,0,16,4" Foreground="{StaticResource CyberMutedBrush}" FontFamily="Consolas" FontSize="12">
                                                                    <Run Text="Input / Cache / Output "/>
                                                                    <Run Text="{Binding InputTokens, StringFormat={}{0:N0}}"/>
                                                                    <Run Text=" / "/>
                                                                    <Run Text="{Binding CachedInputTokens, StringFormat={}{0:N0}}"/>
                                                                    <Run Text=" / "/>
                                                                    <Run Text="{Binding OutputTokens, StringFormat={}{0:N0}}"/>
                                                                </TextBlock>
                                                            </WrapPanel>
                                                        </Grid>
                                                    </Expander.Header>

                                                    <Border Background="{StaticResource CyberInputBrush}"
                                                            BorderBrush="{StaticResource CyberLineBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Padding="12"
                                                            Margin="22,10,0,0">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="160"/>
                                                                    <ColumnDefinition Width="130"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="320"/>
                                                                    <ColumnDefinition Width="110"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="&#x65F6;&#x95F4;" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                                                                <TextBlock Grid.Column="1" Text="&#x6A21;&#x578B;" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                                                                <TextBlock Grid.Column="2" Text="&#x5BF9;&#x8BDD;&#x7247;&#x6BB5;" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                                                                <TextBlock Grid.Column="3" Text="Input / Cache / Output / Reasoning" Style="{StaticResource CyberMutedTextStyle}" FontSize="11"/>
                                                                <TextBlock Grid.Column="4" Text="Token" Style="{StaticResource CyberMutedTextStyle}" FontSize="11" HorizontalAlignment="Right"/>
                                                            </Grid>
                                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Requests}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border BorderBrush="{StaticResource CyberLineBrush}" BorderThickness="0,1,0,0" Padding="0,8">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="160"/>
                                                                                    <ColumnDefinition Width="130"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="320"/>
                                                                                    <ColumnDefinition Width="110"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Text="{Binding Date, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Foreground="{StaticResource CyberTextBrush}" FontFamily="Consolas" FontSize="13"/>
                                                                                <TextBlock Grid.Column="1" Text="{Binding Model}" Style="{StaticResource CyberMutedTextStyle}" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                                                                <TextBlock Grid.Column="2" Text="{Binding ConversationTitle}" Foreground="{StaticResource CyberTextBrush}" TextTrimming="CharacterEllipsis" FontSize="13" Margin="0,0,12,0"/>
                                                                                <TextBlock Grid.Column="3" Foreground="{StaticResource CyberMutedBrush}" FontFamily="Consolas" FontSize="13">
                                                                                    <Run Text="{Binding InputTokens, StringFormat={}{0:N0}}"/>
                                                                                    <Run Text=" / "/>
                                                                                    <Run Text="{Binding CachedInputTokens, StringFormat={}{0:N0}}"/>
                                                                                    <Run Text=" / "/>
                                                                                    <Run Text="{Binding OutputTokens, StringFormat={}{0:N0}}"/>
                                                                                    <Run Text=" / "/>
                                                                                    <Run Text="{Binding ReasoningOutputTokens, StringFormat={}{0:N0}}"/>
                                                                                </TextBlock>
                                                                                <TextBlock Grid.Column="4" Text="{Binding Tokens, StringFormat={}{0:N0}}" Foreground="{StaticResource CyberCyanBrush}" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </Border>
                                                </Expander>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="&#x62A5;&#x544A;">
                    <Border Style="{StaticResource CyberPanelStyle}" Margin="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="&#x590D;&#x5236; Markdown" Command="{Binding CopyReportCommand}" Style="{StaticResource CyberButtonStyle}" Margin="0,0,8,0"/>
                                <Button Content="&#x4FDD;&#x5B58;&#x62A5;&#x544A;" Command="{Binding SaveReportCommand}" Style="{StaticResource CyberGhostButtonStyle}"/>
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     Text="{Binding ReportText}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="12"
                                     Style="{StaticResource CyberTextBoxStyle}"/>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
