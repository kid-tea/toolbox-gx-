<!--
    BatchRenameView.xaml — 批量重命名功能界面
    布局：左栏（文件列表 + 规则编辑）+ 右栏（预览：原名 → 新名）
    支持拖拽添加、6种规则组合、实时预览、撤销
-->
<UserControl x:Class="Toolbox.Views.BatchRenameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Toolbox.Helpers"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:InvertBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <helpers:InvertBoolConverter x:Key="InvBool" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 工具栏 -->
            <RowDefinition Height="*"/>      <!-- 左右两栏主区域 -->
            <RowDefinition Height="Auto"/>   <!-- 进度/状态 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="批量重命名" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

        <!-- 工具栏：添加文件 + 执行 + 撤销 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="添加文件" Command="{Binding BrowseFilesCommand}"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Padding="12,6" Cursor="Hand"
                    Width="100" Height="32" Margin="0,0,8,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}" />
            <Button Content="清空列表" Command="{Binding ClearAllCommand}"
                    Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Padding="12,6" Cursor="Hand"
                    Width="100" Height="32" Margin="0,0,8,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}" />
            <Separator Width="1" Margin="8,4" Background="{StaticResource BorderBrush}" />
            <Button Content="预览" Command="{Binding RefreshPreviewCommand}"
                    Background="{StaticResource SuccessBrush}" Foreground="White"
                    BorderThickness="0" Padding="12,6" Cursor="Hand"
                    Width="80" Height="32" Margin="0,0,8,0"
                    IsEnabled="{Binding HasFiles}" />
            <Button Content="执行重命名" Command="{Binding ExecuteRenameCommand}"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Padding="12,6" Cursor="Hand"
                    FontWeight="Bold" Width="120" Height="32" Margin="0,0,8,0" />
            <Button Content="撤销" Command="{Binding UndoAllCommand}"
                    Background="Transparent" Foreground="{StaticResource WarningBrush}"
                    BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                    Padding="12,6" Cursor="Hand"
                    Width="80" Height="32"
                    IsEnabled="{Binding CanUndo}"
                    ToolTip="撤销最近一次重命名（仅当前会话有效）" />
        </StackPanel>

        <!-- 主区域：左栏 + 右栏 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>   <!-- 左栏：文件列表 + 规则 -->
                <ColumnDefinition Width="5"/>   <!-- 分隔线 -->
                <ColumnDefinition Width="*"/>   <!-- 右栏：预览 -->
            </Grid.ColumnDefinitions>

            <!-- ===== 左栏：文件列表 + 规则编辑 ===== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- 文件列表 -->
                    <RowDefinition Height="5"/>    <!-- 分隔 -->
                    <RowDefinition Height="Auto"/> <!-- 规则参数 -->
                    <RowDefinition Height="Auto"/> <!-- 规则列表 -->
                </Grid.RowDefinitions>

                <!-- 文件列表 -->
                <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Background="{StaticResource InputBackgroundBrush}"
                        AllowDrop="True"
                        PreviewDrop="OnDrop" PreviewDragEnter="OnDragEnter" PreviewDragLeave="OnDragLeave">
                    <Grid Background="Transparent">
                        <TextBlock Text="文件列表（拖放添加）" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding HasFiles, Converter={StaticResource InvBoolToVis}}"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Background="Transparent"
                                      Visibility="{Binding HasFiles, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding FileItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,4" BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- 警告图标 -->
                                                <TextBlock Grid.Column="0" FontSize="12"
                                                           VerticalAlignment="Center" Margin="0,0,4,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value=""/>
                                                            <Setter Property="Foreground" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsErrorWarning}" Value="True">
                                                                    <Setter Property="Text" Value="ER"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsCautionWarning}" Value="True">
                                                                    <Setter Property="Text" Value="!W"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- 原文件名 -->
                                                <TextBlock Grid.Column="1" Text="{Binding OriginalName}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           ToolTip="{Binding WarningMessage}"/>

                                                <!-- 移除按钮 -->
                                                <Button Grid.Column="2" Content="X"
                                                        Command="{Binding DataContext.RemoveFileCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Width="20" Height="20" FontSize="10"
                                                        Background="Transparent"
                                                        Foreground="{StaticResource TextMutedBrush}"
                                                        BorderThickness="0" Cursor="Hand"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- 规则参数编辑区 -->
                <Border Grid.Row="2" Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="8" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="添加重命名规则" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox SelectedIndex="{Binding SelectedRuleTypeIndex}"
                                      Width="120" Height="28" Margin="0,0,8,0"
                                      Background="{StaticResource InputBackgroundBrush}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource BorderBrush}">
                                <ComboBoxItem Content="添加前缀"/>
                                <ComboBoxItem Content="添加后缀"/>
                                <ComboBoxItem Content="查找替换"/>
                                <ComboBoxItem Content="序号"/>
                                <ComboBoxItem Content="移除字符"/>
                                <ComboBoxItem Content="大小写"/>
                                <ComboBoxItem Content="正则表达式"/>
                                <ComboBoxItem Content="整体重命名"/>
                                <ComboBoxItem Content="格式/扩展名"/>
                            </ComboBox>
                            <TextBox Text="{Binding RuleParam1, UpdateSourceTrigger=PropertyChanged}"
                                     Width="130" Height="28" Margin="0,0,4,0"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     ToolTip="参数1（如前缀文本、查找文本等）"/>
                            <TextBox Text="{Binding RuleParam2, UpdateSourceTrigger=PropertyChanged}"
                                     Width="130" Height="28" Margin="0,0,4,0"
                                     Background="{StaticResource InputBackgroundBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     ToolTip="参数2（如替换文本等）"/>
                            <Button Content="+" Command="{Binding AddRuleCommand}"
                                    Background="{StaticResource AccentBrush}" Foreground="White"
                                    BorderThickness="0" Width="28" Height="28" Cursor="Hand"
                                    FontWeight="Bold" FontSize="16"
                                    ToolTip="添加规则"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 规则列表 -->
                <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4" Margin="0,4,0,0"
                        MaxHeight="100">
                    <ItemsControl ItemsSource="{Binding Rules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Description}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="UP" FontSize="10"
                                                    Command="{Binding DataContext.MoveRuleUpCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    Foreground="{StaticResource TextMutedBrush}"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Width="24" Height="20"/>
                                            <Button Content="DN" FontSize="10"
                                                    Command="{Binding DataContext.MoveRuleDownCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    Foreground="{StaticResource TextMutedBrush}"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Width="24" Height="20"/>
                                            <Button Content="X" FontSize="10"
                                                    Command="{Binding DataContext.RemoveRuleCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    Foreground="{StaticResource DangerBrush}"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Width="20" Height="20"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Grid>

            <!-- 分隔线 -->
            <GridSplitter Grid.Column="1" Width="5"
                          Background="{StaticResource BorderBrush}"
                          HorizontalAlignment="Stretch" />

            <!-- ===== 右栏：预览 ===== -->
            <Grid Grid.Column="2" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 预览标题和统计 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="预览" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding PreviewSummary}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 预览列表：原名 → 新名 -->
                <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FileItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6,4" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Border.Resources>
                                            <helpers:StringToVisibilityConverter x:Key="StrToVis"/>
                                        </Border.Resources>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 原文件名 -->
                                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                <TextBlock Text="原名: " FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding OriginalName}" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- 新文件名（箭头） -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                                <TextBlock Text="  →  " FontSize="12"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                                <TextBlock FontSize="12" FontWeight="Bold"
                                                           TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding NewName}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsErrorWarning}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsCautionWarning}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Success">
                                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                                    <Setter Property="Text" Value="{Binding OriginalName}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- 警告消息 -->
                                            <TextBlock Grid.Row="2" Text="{Binding WarningMessage}"
                                                       FontSize="10" Margin="8,0,0,0"
                                                       Foreground="{StaticResource DangerBrush}"
                                                       Visibility="{Binding WarningMessage,
                                                           Converter={StaticResource StrToVis}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- 进度条 + 结果统计 -->
        <Grid Grid.Row="3" Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- 进度条 -->
            <Grid Grid.Row="0" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <ProgressBar Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                             Height="6"
                             Foreground="{StaticResource AccentBrush}"
                             Background="{StaticResource CardBrush}"
                             BorderThickness="0"/>
            </Grid>
            <!-- 状态 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="{Binding ProgressText}" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock Text="{Binding ResultSummary}" FontSize="12" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="16,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
