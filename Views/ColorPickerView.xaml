<!--
    ColorPickerView.xaml — 取色器功能页面
    布局：取色按钮/状态 → 颜色预览 → 颜色格式（HEX/RGB/HSL） → 取色历史列表
    所有颜色使用 {StaticResource ...} 引用主题
-->
<UserControl x:Class="Toolbox.Views.ColorPickerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Toolbox.ViewModels"
             Background="{StaticResource ContentBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="WpfBoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>       <!-- 取色按钮 -->
            <RowDefinition Height="Auto"/>       <!-- 状态信息 -->
            <RowDefinition Height="Auto"/>       <!-- 颜色预览 + 放大镜 -->
            <RowDefinition Height="Auto"/>       <!-- 颜色格式（HEX/RGB/HSL） -->
            <RowDefinition Height="*"/>          <!-- 取色历史列表 -->
        </Grid.RowDefinitions>

        <!-- ========== 第1行：取色按钮 ========== -->
        <Border Grid.Row="0" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource DefaultCornerRadius}" Padding="16" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 开始取色按钮 -->
                <Button Content="🎨 开始取色"
                        Command="{Binding StartPickingCommand}"
                        IsEnabled="{Binding IsPicking, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"
                        Width="140" Height="44"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        FontWeight="Bold" FontSize="16">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- 取色状态提示 -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                               TextWrapping="Wrap"/>
                    <!-- 取色进行中提示 -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsPicking, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,4,0,0">
                        <TextBlock Text="取色中 — 鼠标左键锁定颜色，Esc 取消"
                                   Foreground="{StaticResource AccentBrush}" FontSize="12"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== 第2行：状态栏（坐标信息） ========== -->
        <Border Grid.Row="1" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="屏幕坐标:" Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                           Visibility="{Binding IsPicking, Converter={StaticResource BoolToVisibilityConverter}}"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding MouseX, StringFormat='X={0}'}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           Visibility="{Binding IsPicking, Converter={StaticResource BoolToVisibilityConverter}}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding MouseY, StringFormat='Y={0}'}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           Visibility="{Binding IsPicking, Converter={StaticResource BoolToVisibilityConverter}}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ========== 第3行：颜色预览 + 放大镜 ========== -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 颜色大色块预览 -->
            <Border Grid.Column="0" Width="120" Height="120"
                    CornerRadius="{StaticResource DefaultCornerRadius}"
                    Background="{Binding CurrentColorBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>

            <!-- 放大镜预览 -->
            <Border Grid.Column="1" Width="200" Height="200"
                    Margin="16,0,0,0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="{StaticResource DefaultCornerRadius}"
                    Background="{StaticResource CardBrush}">
                <Grid>
                    <!-- 放大镜图像 -->
                    <Image Source="{Binding MagnifierImage}" Stretch="Fill"/>
                    <!-- 取色中十字线 -->
                    <Grid Visibility="{Binding IsPicking, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Line X1="0" Y1="100" X2="200" Y2="100"
                              Stroke="Red" StrokeThickness="1"/>
                        <Line X1="100" Y1="0" X2="100" Y2="200"
                              Stroke="Red" StrokeThickness="1"/>
                    </Grid>
                    <!-- 未取色时的提示 -->
                    <TextBlock Text="放大镜预览"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsPicking, Converter={StaticResource InvertBoolToVisibilityConverter}}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== 第4行：颜色格式（HEX/RGB/HSL） — 点击复制 ========== -->
        <Border Grid.Row="3" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource DefaultCornerRadius}" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- HEX 格式 -->
                <StackPanel Grid.Column="0" Cursor="Hand"
                            ToolTip="点击复制 HEX 值"
                            MouseLeftButtonDown="OnHexClick">
                    <TextBlock Text="HEX" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding HexValue}"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold"
                               FontFamily="Consolas"/>
                </StackPanel>

                <!-- RGB 格式 -->
                <StackPanel Grid.Column="1" Cursor="Hand" Margin="16,0,0,0"
                            ToolTip="点击复制 RGB 值"
                            MouseLeftButtonDown="OnRgbClick">
                    <TextBlock Text="RGB" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding RgbValue}"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold"
                               FontFamily="Consolas"/>
                </StackPanel>

                <!-- HSL 格式 -->
                <StackPanel Grid.Column="2" Cursor="Hand" Margin="16,0,0,0"
                            ToolTip="点击复制 HSL 值"
                            MouseLeftButtonDown="OnHslClick">
                    <TextBlock Text="HSL" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding HslValue}"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold"
                               FontFamily="Consolas"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== 第5行：取色历史列表 ========== -->
        <Border Grid.Row="4" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource DefaultCornerRadius}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="取色历史" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ColorHistory.Count, StringFormat=' ({0})'}"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <Button Content="清除历史"
                            Command="{Binding ClearHistoryCommand}"
                            Margin="12,0,0,0" Padding="8,4"
                            Background="{StaticResource DangerBrush}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="11">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- 历史列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ColorHistory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,4" Padding="6"
                                        Background="Transparent"
                                        Cursor="Hand"
                                        CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- 颜色色块（点击选中） -->
                                        <Border Width="32" Height="32"
                                                Background="{Binding ColorBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Cursor="Hand"/>
                                        <!-- HEX 值 -->
                                        <TextBlock Text="{Binding HexValue}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontFamily="Consolas" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,12,0"/>
                                        <!-- 时间 -->
                                        <TextBlock Text="{Binding Time}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 空状态 -->
                <TextBlock Grid.Row="1" Text="暂无取色历史 — 点击「开始取色」并左键锁定颜色"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
