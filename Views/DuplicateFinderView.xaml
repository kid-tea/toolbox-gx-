<!--
    DuplicateFinderView.xaml — 重复文件查找页面
    布局：
      顶部：操作栏（扫描范围选择 + 哈希算法 + 文件类型过滤器 + 扫描按钮）
      中部：重复组列表（每组可展开查看文件详情）
      底部：统计栏
    受保护路径文件安全标记
-->
<UserControl x:Class="Toolbox.Views.DuplicateFinderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Toolbox.Views"
             xmlns:services="clr-namespace:Toolbox.Services"
             xmlns:viewmodels="clr-namespace:Toolbox.ViewModels"
             xmlns:converters="clr-namespace:Toolbox.Converters"
             Background="{StaticResource ContentBrush}">

    <!-- 值转换器 -->
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolInverseConverter x:Key="BoolInverseConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 操作面板 -->
            <RowDefinition Height="Auto"/>   <!-- 状态/进度 -->
            <RowDefinition Height="*"/>      <!-- 重复组列表 -->
            <RowDefinition Height="Auto"/>   <!-- 底部统计栏 -->
        </Grid.RowDefinitions>

        <!-- ========== 标题 ========== -->
        <TextBlock Grid.Row="0" Text="重复文件查找" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

        <!-- ========== 操作面板 ========== -->
        <Border Grid.Row="1" Padding="12,8" Margin="0,0,0,8"
                Background="{StaticResource CardBrush}" CornerRadius="4"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel>
            <WrapPanel>
                <!-- 扫描范围选择 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="扫描范围:" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button Content="智能选择" FontSize="12" Height="32" Width="96"
                            Padding="12,4"
                            Command="{Binding ChooseScanPathsCommand}"
                            Background="Transparent"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Cursor="Hand"/>
                </StackPanel>

                <!-- 哈希算法 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="算法:" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox ItemsSource="{Binding HashModeOptions}"
                              SelectedIndex="{Binding SelectedHashModeIndex}"
                              Height="28" Width="180" FontSize="12"/>
                </StackPanel>

                <!-- 文件类型过滤 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="类型:" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Text="{Binding FileFilter, UpdateSourceTrigger=PropertyChanged}"
                             Width="120" Height="26"
                             VerticalContentAlignment="Center" FontSize="12"
                             ToolTip="如: *.jpg;*.png;*.mp4"/>
                </StackPanel>

                <!-- 扫描按钮 -->
                <Button Content="🔍 扫描重复文件"
                        Command="{Binding ScanCommand}"
                        Height="28" Width="130" FontSize="12"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource BoolInverseConverter}}"/>

                <!-- 取消按钮 -->
                <Button Content="✖ 取消"
                        Command="{Binding CancelScanCommand}"
                        Height="28" Width="60" FontSize="12" Margin="4,0,0,0"
                        Background="Transparent"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" Cursor="Hand"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- 删除重复文件 -->
                <Button Content="🗑️ 删除重复"
                        Command="{Binding DeleteDuplicatesCommand}"
                        Height="28" Width="110" FontSize="12" Margin="12,0,0,0"
                        Background="{StaticResource DangerBrush}" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </WrapPanel>

            <!-- 可选扫描范围列表，让用户真正能选磁盘 -->
            <ItemsControl ItemsSource="{Binding ScanPaths}" Margin="0,10,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" Margin="0,0,12,6"
                                  Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ========== 状态/进度 ========== -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13" TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
            <ProgressBar Value="{Binding ProgressValue}"
                         Maximum="{Binding ProgressMax}"
                         IsIndeterminate="{Binding IsProgressIndeterminate}"
                         Height="4"
                         Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <!-- ========== 重复组列表 ========== -->
        <Border Grid.Row="3"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DuplicateGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type services:DuplicateGroup}">
                            <!-- 每个重复组 -->
                            <Expander IsExpanded="False" Margin="0,1,0,1">
                                <Expander.Header>
                                    <!-- 重复组摘要 -->
                                    <Border Padding="10,8"
                                            Background="{StaticResource CardBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 组信息 -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="📁" FontSize="14"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding DuplicateCount, StringFormat='{}{0} 个重复文件'}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text=" | " Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="12" Margin="4,0"/>
                                                <TextBlock Text="{Binding FileSizeDisplay}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontSize="12" FontWeight="SemiBold"/>
                                                <TextBlock Text=" / 个" Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="11"/>
                                            </StackPanel>

                                            <!-- 哈希 -->
                                            <TextBlock Grid.Column="1" Text="{Binding Hash}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10" VerticalAlignment="Center"
                                                       Margin="0,0,12,0"/>

                                            <!-- 浪费空间 -->
                                            <TextBlock Grid.Column="2" Text="{Binding WastedSpaceDisplay, StringFormat='浪费: {0}'}"
                                                       Foreground="{StaticResource DangerBrush}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Margin="0,0,12,0"/>

                                            <!-- 安全警告 -->
                                            <Border Grid.Column="3"
                                                    Background="{StaticResource WarningBrush}" CornerRadius="4"
                                                    Padding="6,2"
                                                    Visibility="{Binding HasProtectedFiles, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="含受保护文件" Foreground="White" FontSize="10"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Expander.Header>

                                <!-- 展开后：文件列表 -->
                                <ItemsControl ItemsSource="{Binding Files}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type services:DuplicateFileInfo}">
                                            <Border Padding="16,6"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Background="{StaticResource ContentBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 保留标记 -->
                                                    <CheckBox Grid.Column="0"
                                                              Content="保留"
                                                              IsChecked="{Binding IsMarkedToKeep}"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,8,0"
                                                              Foreground="{StaticResource TextSecondaryBrush}"
                                                              FontSize="11"/>

                                                    <!-- 文件名 + 路径 -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <!-- 受保护标记 -->
                                                            <Border CornerRadius="3"
                                                                    Background="{StaticResource DangerBrush}"
                                                                    Padding="4,1" Margin="6,0,0,0"
                                                                    Visibility="{Binding IsProtected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <TextBlock Text="受保护" Foreground="White" FontSize="9"/>
                                                            </Border>
                                                            <!-- 最早文件标记 -->
                                                            <Border CornerRadius="3"
                                                                    Background="{StaticResource SuccessBrush}"
                                                                    Padding="4,1" Margin="4,0,0,0"
                                                                    Visibility="{Binding IsMarkedToKeep, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <TextBlock Text="将保留" Foreground="White" FontSize="9"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding FullPath}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="10"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <!-- 大小 -->
                                                    <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontSize="11" VerticalAlignment="Center"
                                                               Margin="0,0,8,0"/>

                                                    <!-- 日期 -->
                                                    <TextBlock Grid.Column="3" Text="{Binding DateDisplay}"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontSize="11" VerticalAlignment="Center"
                                                               Margin="0,0,8,0"/>

                                                    <!-- 操作按钮 -->
                                                    <Button Grid.Column="4" Content="📂"
                                                            Width="28" Height="22" FontSize="11"
                                                            Background="Transparent" BorderThickness="0"
                                                            Cursor="Hand"
                                                            ToolTip="打开文件位置"
                                                            Command="{Binding DataContext.OpenFileLocationCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ========== 底部统计栏 ========== -->
        <Border Grid.Row="4" Padding="12,6"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="0,6,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="重复组: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                <TextBlock Text="{Binding TotalGroupCount}" Foreground="{StaticResource AccentBrush}"
                           FontSize="12" FontWeight="Bold"/>
                <TextBlock Text=" 组" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>

                <TextBlock Text=" | 文件: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           Margin="12,0,0,0"/>
                <TextBlock Text="{Binding TotalFileCount}" Foreground="{StaticResource AccentBrush}"
                           FontSize="12" FontWeight="Bold"/>
                <TextBlock Text=" 个" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>

                <TextBlock Text=" | 可释放: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           Margin="12,0,0,0"/>
                <TextBlock Text="{Binding TotalWastedSpace}" Foreground="{StaticResource DangerBrush}"
                           FontSize="12" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
