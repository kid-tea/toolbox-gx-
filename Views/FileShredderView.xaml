<!--
    FileShredderView.xaml — 文件粉碎功能界面
    布局：拖放区域 + 文件列表（含后果说明） + 算法选择 + 粉碎按钮 + 操作日志
    支持拖拽添加、算法选择、L3四重确认、日志显示
-->
<UserControl x:Class="Toolbox.Views.FileShredderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Toolbox.Helpers"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:InvertBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <helpers:InvertBoolConverter x:Key="InvBool" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 按钮栏 + 算法选择 -->
            <RowDefinition Height="*"/>      <!-- 文件列表（支持拖放添加） -->
            <RowDefinition Height="Auto"/>   <!-- 进度条 -->
            <RowDefinition Height="2*"/>     <!-- 操作日志 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="文件粉碎" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

        <!-- 按钮栏 + 算法选择 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="添加文件" Command="{Binding BrowseFilesCommand}"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        BorderThickness="0" Padding="12,6" Cursor="Hand"
                        Width="100" Height="32" Margin="0,0,8,0"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}" />
                <Button Content="清空列表" Command="{Binding ClearAllCommand}"
                        Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="12,6" Cursor="Hand"
                        Width="100" Height="32" Margin="0,0,8,0"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}" />
                <Separator Width="1" Margin="8,4" Background="{StaticResource BorderBrush}" />
                <!-- 粉碎按钮 -->
                <Button Content="粉碎文件" Command="{Binding ExecuteShredCommand}"
                        Background="{StaticResource DangerBrush}" Foreground="White"
                        BorderThickness="0" Padding="12,6" Cursor="Hand"
                        FontWeight="Bold" Width="120" Height="32" Margin="0,0,8,0"
                        ToolTip="执行四重确认后永久销毁文件" />
                <!-- 取消按钮（执行中可见） -->
                <Button Content="取消" Command="{Binding CancelShredCommand}"
                        Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="12,6" Cursor="Hand"
                        Width="80" Height="32"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                        ToolTip="取消正在执行的粉碎操作" />
            </StackPanel>

            <!-- 算法选择 -->
            <Border Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="覆写算法:" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,8,0"/>
                        <ComboBox SelectedIndex="{Binding SelectedAlgorithmIndex}"
                                  Width="150" Height="28"
                                  Background="{StaticResource InputBackgroundBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <ComboBoxItem Content="快速 (1次覆写)"/>
                            <ComboBoxItem Content="安全 (3次覆写)"/>
                            <ComboBoxItem Content="彻底 (7次覆写)"/>
                        </ComboBox>
                    </StackPanel>
                    <TextBlock Text="{Binding AlgorithmDescription}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 文件列表（支持拖放添加） -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Margin="0,0,0,8"
                Background="{StaticResource InputBackgroundBrush}"
                AllowDrop="True"
                DragEnter="OnDragEnter" DragLeave="OnDragLeave" Drop="OnDrop">
            <Grid>
                <!-- 空列表提示 -->
                <TextBlock Text="暂无文件，请拖放或点击添加文件按钮"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"
                           Visibility="{Binding HasFiles, Converter={StaticResource InvBoolToVis}}"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasFiles, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding FileItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>  <!-- 状态 -->
                                            <ColumnDefinition Width="*"/>   <!-- 文件名+后果 -->
                                            <ColumnDefinition Width="80"/>  <!-- 大小 -->
                                            <ColumnDefinition Width="36"/>  <!-- 移除 -->
                                        </Grid.ColumnDefinitions>

                                        <!-- 状态图标 -->
                                        <TextBlock Grid.Column="0" FontSize="14"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value=""/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Success">
                                                            <Setter Property="Text" Value="OK"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Text" Value="FAIL"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Skipped">
                                                            <Setter Property="Text" Value="SKIP"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- 文件名 + 后果/安全标记 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                            <TextBlock Text="{Binding FileName}" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Consequence}" FontSize="11"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- 文件大小 -->
                                        <TextBlock Grid.Column="2" Text="{Binding FileSize}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- 移除按钮 -->
                                        <Button Grid.Column="3" Content="X"
                                                Command="{Binding DataContext.RemoveFileCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Width="24" Height="24" FontSize="11"
                                                Background="Transparent"
                                                Foreground="{StaticResource TextMutedBrush}"
                                                BorderThickness="0" Cursor="Hand"
                                                ToolTip="移除此文件"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 进度条 -->
        <Grid Grid.Row="3" Margin="0,0,0,8"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <ProgressBar Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                             Height="6"
                             Foreground="{StaticResource AccentBrush}"
                             Background="{StaticResource CardBrush}"
                             BorderThickness="0"/>
                <TextBlock Text="{Binding ProgressText}" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Right" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 操作日志 -->
        <Border Grid.Row="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 日志标题栏 -->
                <Border Grid.Row="0" Background="{StaticResource CardBrush}" Padding="8,4"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="操作日志" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Button Content="清空日志" HorizontalAlignment="Right"
                                Command="{Binding ClearLogsCommand}"
                                Background="Transparent"
                                Foreground="{StaticResource TextMutedBrush}"
                                BorderThickness="0" Cursor="Hand" FontSize="11"
                                Visibility="{Binding HasLogs, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Border>

                <!-- 日志内容 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding OperationLogs}"
                                  Margin="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12" FontFamily="Consolas, monospace"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,1,0,0"
                                           TextWrapping="NoWrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
