<!--
    ForceDeleteView.xaml — 文件强制删除功能界面
    布局：顶部拖放区域 + 中部文件列表 + 底部操作按钮 + 结果展示
    支持拖拽添加、浏览添加、批量删除、L1确认、结果显示
-->
<UserControl x:Class="Toolbox.Views.ForceDeleteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Toolbox.Helpers"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <!-- 本地转换器资源 -->
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
        <helpers:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisConverter" />
        <helpers:InvertBoolConverter x:Key="InvertBoolConverter" />
        <helpers:StringToVisibilityConverter x:Key="StringToVisConverter" />

        <!-- 按钮样式：主要操作（蓝色） -->
        <Style x:Key="PrimaryBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- 按钮样式：次要操作（灰色边框） -->
        <Style x:Key="SecondaryBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- 按钮样式：危险操作（红色） -->
        <Style x:Key="DangerBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 按钮栏 -->
            <RowDefinition Height="*"/>      <!-- 文件列表（支持拖放添加） -->
            <RowDefinition Height="Auto"/>   <!-- 进度条 -->
            <RowDefinition Height="Auto"/>   <!-- 底部状态 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="文件强制删除" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

        <!-- 按钮栏：浏览添加文件、浏览添加文件夹、清空列表 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="添加文件" Command="{Binding BrowseFilesCommand}"
                    Style="{StaticResource PrimaryBtnStyle}" Width="100" Height="32"
                    Margin="0,0,8,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
            <Button Content="添加文件夹" Command="{Binding BrowseFolderCommand}"
                    Style="{StaticResource SecondaryBtnStyle}" Width="100" Height="32"
                    Margin="0,0,8,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
            <Button Content="清空列表" Command="{Binding ClearAllCommand}"
                    Style="{StaticResource SecondaryBtnStyle}" Width="100" Height="32"
                    Margin="0,0,8,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
            <!-- 分隔 -->
            <Separator Width="1" Margin="8,4" Background="{StaticResource BorderBrush}" />
            <!-- 删除按钮 -->
            <Button Content="强制删除" Command="{Binding ExecuteDeleteCommand}"
                    Style="{StaticResource DangerBtnStyle}" Width="120" Height="32"
                    IsEnabled="{Binding HasFiles}"
                    ToolTip="终止占用进程并强制删除文件" />
        </StackPanel>

        <!-- 文件列表（支持拖放添加） -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4"
                Background="{StaticResource InputBackgroundBrush}"
                AllowDrop="True"
                DragEnter="OnDragEnter" DragLeave="OnDragLeave" Drop="OnDrop">
            <Grid>
                <!-- 空列表提示 -->
                <TextBlock Text="暂无文件，请拖放或点击上方按钮添加"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasFiles}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 文件列表滚动视图 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FileItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- 每行：状态图标 + 文件名 + 大小 + 移除按钮 -->
                                <Border Padding="8,6"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>  <!-- 状态图标 -->
                                            <ColumnDefinition Width="*"/>   <!-- 文件名和错误 -->
                                            <ColumnDefinition Width="80"/>  <!-- 文件大小 -->
                                            <ColumnDefinition Width="36"/>  <!-- 移除按钮 -->
                                        </Grid.ColumnDefinitions>

                                        <!-- 状态图标 -->
                                        <TextBlock Grid.Column="0" Text="{Binding ResultIcon}"
                                                   FontSize="16" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>

                                        <!-- 文件名和错误信息 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                            <TextBlock Text="{Binding FileName}" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <!-- 受保护路径警告 -->
                                            <TextBlock Text="⚠ 该文件位于系统受保护路径，无法强制删除" FontSize="11"
                                                       Foreground="{StaticResource DangerBrush}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding IsProtected,
                                                           Converter={StaticResource BoolToVisConverter}}"/>
                                            <TextBlock Text="{Binding ErrorMessage}" FontSize="11"
                                                       Foreground="{StaticResource DangerBrush}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding ErrorMessage,
                                                           Converter={StaticResource StringToVisConverter}}"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding LockingProcessNames,
                                                           Converter={StaticResource StringToVisConverter}}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="占用进程: {0}">
                                                        <Binding Path="LockingProcessNames"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <!-- .lnk 快捷方式标记 -->
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"
                                                                Value="{Binding ShortcutTarget, StringFormat='快捷方式目标: {0}'}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsShortcut}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- 文件大小 -->
                                        <TextBlock Grid.Column="2" Text="{Binding FileSize}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                        <!-- 移除按钮 -->
                                        <Button Grid.Column="3" Content="X"
                                                Command="{Binding DataContext.RemoveFileCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Width="24" Height="24"
                                                FontSize="11"
                                                Background="Transparent"
                                                Foreground="{StaticResource TextMutedBrush}"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                ToolTip="移除此文件"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 进度条区域 -->
        <Grid Grid.Row="3" Margin="0,8,0,0"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}">
            <StackPanel>
                <ProgressBar Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                             Height="6"
                             Foreground="{StaticResource AccentBrush}"
                             Background="{StaticResource CardBrush}"
                             BorderThickness="0"/>
                <TextBlock Text="{Binding ProgressText}" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Right" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 底部状态文本（非忙碌时显示） -->
        <TextBlock Grid.Row="4" Text="{Binding ProgressText}" FontSize="12"
                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"
                   Visibility="{Binding IsBusy, Converter={StaticResource InvertBoolToVisConverter}}"/>
    </Grid>
</UserControl>
