<!--
    LargeFileScannerView.xaml — 大文件扫描页面
    布局：
      左侧：磁盘多选列表 + 阈值选择 + 扫描按钮
      右侧：文件列表（名称+路径+大小+日期） + 右键菜单
-->
<UserControl x:Class="Toolbox.Views.LargeFileScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Toolbox.Views"
             xmlns:viewmodels="clr-namespace:Toolbox.ViewModels"
             xmlns:converters="clr-namespace:Toolbox.Converters"
             Background="{StaticResource ContentBrush}">

    <!-- 值转换器 -->
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolInverseConverter x:Key="BoolInverseConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 状态/进度 -->
            <RowDefinition Height="*"/>      <!-- 主体 -->
            <RowDefinition Height="Auto"/>   <!-- 底部 -->
        </Grid.RowDefinitions>

        <!-- ========== 标题 ========== -->
        <Border Grid.Row="0" Padding="0,0,0,8">
            <TextBlock Text="大文件扫描" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
        </Border>

        <!-- ========== 状态/进度 ========== -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13" TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
            <ProgressBar Value="{Binding ProgressValue}"
                         Maximum="{Binding ProgressMax}"
                         IsIndeterminate="{Binding IsProgressIndeterminate}"
                         Height="4"
                         Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <!-- ========== 主体 ========== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <!-- 左侧控制面板 -->
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="Auto"/>
                <!-- 右侧文件列表 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧：磁盘选择 + 阈值 + 操作按钮 ===== -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4"
                    Background="{StaticResource CardBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,10">
                        <!-- 磁盘选择 -->
                        <TextBlock Text="选择磁盘" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Disks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewmodels:DiskModel}">
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="12" Margin="0,0,0,4"
                                              ToolTip="{Binding Label}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 分隔 -->
                        <Separator Margin="0,10" Background="{StaticResource BorderBrush}"/>

                        <!-- 阈值选择 -->
                        <TextBlock Text="文件大小阈值" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding ThresholdOptions}"
                                  SelectedIndex="{Binding SelectedThresholdIndex}"
                                  Height="30" FontSize="12"
                                  Margin="0,0,0,8"/>

                        <!-- 自定义阈值 -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsCustomThresholdVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,0,0,8">
                            <TextBox Text="{Binding CustomThresholdMB, UpdateSourceTrigger=PropertyChanged}"
                                     Width="70" Height="26"
                                     VerticalContentAlignment="Center" FontSize="12"/>
                            <TextBlock Text=" MB" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>

                        <!-- 分隔 -->
                        <Separator Margin="0,10" Background="{StaticResource BorderBrush}"/>

                        <!-- 操作按钮 -->
                        <Button Content="🔍 开始扫描"
                                Command="{Binding ScanCommand}"
                                Height="32"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                IsEnabled="{Binding IsScanning, Converter={StaticResource BoolInverseConverter}}"/>
                        <Button Content="✖ 取消"
                                Command="{Binding CancelScanCommand}"
                                Height="28" Margin="0,4,0,0"
                                Background="Transparent"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Cursor="Hand"
                                Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- 分隔 -->
                        <Separator Margin="0,10" Background="{StaticResource BorderBrush}"/>

                        <!-- 删除选中 -->
                        <Button Content="🗑️ 删除选中"
                                Command="{Binding DeleteSelectedCommand}"
                                Height="32"
                                Background="{StaticResource DangerBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 分隔条 -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <!-- ===== 右侧：文件列表 ===== -->
            <Grid Grid.Column="2" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 统计信息 -->
                <Border Grid.Row="0" Padding="8,6" Margin="0,0,0,4"
                        Background="{StaticResource CardBrush}"
                        CornerRadius="4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="共找到 " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding TotalFileCount}" Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text=" 个文件" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock Text="，总大小 " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                   Margin="8,0,0,0"/>
                        <TextBlock Text="{Binding TotalSizeDisplay}" Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- 文件列表 -->
                <Border Grid.Row="1"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Files}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewmodels:LargeFileInfo}">
                                    <!-- 每个文件行 -->
                                    <Border Padding="10,6"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Background="{StaticResource CardBrush}">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="打开文件位置"
                                                          Command="{Binding DataContext.OpenFileLocationCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="删除文件"
                                                          Command="{Binding DataContext.DeleteSelectedCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          IsEnabled="{Binding IsProtected, Converter={StaticResource BoolInverseConverter}}"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>   <!-- CheckBox -->
                                                <ColumnDefinition Width="*"/>      <!-- 名 称 + 路径 -->
                                                <ColumnDefinition Width="100"/>    <!-- 大小 -->
                                                <ColumnDefinition Width="140"/>    <!-- 日期 -->
                                                <ColumnDefinition Width="Auto"/>   <!-- 操作按钮 -->
                                            </Grid.ColumnDefinitions>

                                            <!-- 选择框 -->
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"
                                                      Checked="OnFileChecked"
                                                      Unchecked="OnFileUnchecked"/>

                                            <!-- 文件名 + 路径 -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FullPath}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- 大小 -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding SizeDisplay}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,0,8,0"/>

                                            <!-- 日期 -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding DateDisplay}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>

                                            <!-- 操作按钮：受保护文件置灰 -->
                                            <StackPanel Grid.Column="4" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Content="📂"
                                                        Command="{Binding DataContext.OpenFileLocationCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Width="28" Height="24" FontSize="12"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        ToolTip="打开文件位置"/>
                                                <Button Content="🗑️"
                                                        Width="28" Height="24" FontSize="12"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        IsEnabled="{Binding IsProtected, Converter={StaticResource BoolInverseConverter}}"
                                                        ToolTip="{Binding IsProtected, StringFormat='{}{0:受保护文件不可删除|删除文件}'}"
                                                        Click="OnDeleteFileClicked"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- ========== 底部统计栏 ========== -->
        <Border Grid.Row="3" Padding="12,6"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="0,6,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="选中文件: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                <TextBlock Text="{Binding SelectedSizeDisplay}"
                           Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
