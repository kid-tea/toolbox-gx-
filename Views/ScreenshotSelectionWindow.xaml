<!--
    ScreenshotSelectionWindow.xaml — 屏幕区域选择覆盖窗口
    全屏透明窗口，用户鼠标拖拽选择截图区域
-->
<Window x:Class="Toolbox.Views.ScreenshotSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择截图区域"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStartupLocation="Manual"
        Cursor="Cross"
        KeyDown="OnKeyDown"
        Loaded="OnLoaded">
    <Grid Background="#33000000">
        <Canvas x:Name="OverlayCanvas" Background="Transparent"/>
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,36,0,0"
                Padding="16,10"
                Background="#DD111827"
                BorderBrush="#6600AEEF"
                BorderThickness="1"
                CornerRadius="8"
                IsHitTestVisible="False">
            <TextBlock Text="拖拽选择截图区域，松开鼠标完成；右键或 Esc 取消"
                       Foreground="#F8FAFC"
                       FontSize="15"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
