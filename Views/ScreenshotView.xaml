<!--
    ScreenshotView.xaml — 截屏功能页面
    清新现代布局：模式选择 + 截屏按钮 + 预览区 + 标注工具 + 操作按钮
-->
<UserControl x:Class="Toolbox.Views.ScreenshotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Toolbox.ViewModels"
             Background="{StaticResource ContentBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== 标题 + 模式 + 截屏按钮 ========== -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="截屏" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="支持全屏 / 区域 / 窗口 / 延时截图，可标注后保存"
                           FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource DefaultCornerRadius}" Padding="4">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="全屏" Command="{Binding SetModeCommand}" CommandParameter="FullScreen"
                                Style="{StaticResource SecondaryBtnStyle}" Padding="12,6" Margin="0,0,2,0"
                                FontSize="12"/>
                        <Button Content="区域" Command="{Binding SetModeCommand}" CommandParameter="Region"
                                Style="{StaticResource SecondaryBtnStyle}" Padding="12,6" Margin="0,0,2,0"
                                FontSize="12"/>
                        <Button Content="窗口" Command="{Binding SetModeCommand}" CommandParameter="Window"
                                Style="{StaticResource SecondaryBtnStyle}" Padding="12,6" Margin="0,0,2,0"
                                FontSize="12"/>
                        <Button Content="延时" Command="{Binding SetModeCommand}" CommandParameter="Delayed"
                                Style="{StaticResource SecondaryBtnStyle}" Padding="12,6"
                                FontSize="12"/>
                    </StackPanel>
                </Border>
                <Button Content="📷 截屏" Command="{Binding CaptureCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="20,10" Margin="8,0,0,0"
                        FontSize="14"/>
            </StackPanel>
        </Grid>

        <!-- ========== 状态信息 + 延时设置 ========== -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource DefaultCornerRadius}" Padding="10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ProgressBar Width="160" Height="4"
                                 Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}"
                                 IsIndeterminate="{Binding IsProgressIndeterminate}"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource BorderBrush}"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== 预览区 ========== -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource DefaultCornerRadius}"
                ClipToBounds="True">
            <Grid>
                <TextBlock Text="点击「📷 截屏」开始截图"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="16"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasResult, Converter={StaticResource InverseBoolConverter}}"/>
                <Grid Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ScrollViewer x:Name="PreviewScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Image x:Name="PreviewImage" Source="{Binding CapturedImage}"
                                   Stretch="None" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <Canvas x:Name="AnnotationCanvas"
                                    Width="{Binding CapturedImage.PixelWidth}"
                                    Height="{Binding CapturedImage.PixelHeight}"
                                    MouseLeftButtonDown="OnAnnotationCanvasMouseDown"
                                    MouseMove="OnAnnotationCanvasMouseMove"
                                    MouseLeftButtonUp="OnAnnotationCanvasMouseUp"
                                    Background="Transparent"
                                    Cursor="Cross"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- ========== 标注工具 + 操作按钮 ========== -->
        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <!-- 标注工具栏 -->
            <Border Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="{StaticResource DefaultCornerRadius}" Padding="8"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}"
                    Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="↖ 选择" Command="{Binding SetAnnotationToolCommand}" CommandParameter="Select"
                            Style="{StaticResource SecondaryBtnStyle}" Padding="8,4" Margin="0,0,4,0" FontSize="11"/>
                    <Button Content="▭ 矩形" Command="{Binding SetAnnotationToolCommand}" CommandParameter="Rectangle"
                            Style="{StaticResource SecondaryBtnStyle}" Padding="8,4" Margin="0,0,4,0" FontSize="11"/>
                    <Button Content="→ 箭头" Command="{Binding SetAnnotationToolCommand}" CommandParameter="Arrow"
                            Style="{StaticResource SecondaryBtnStyle}" Padding="8,4" Margin="0,0,4,0" FontSize="11"/>
                    <Button Content="T 文字" Command="{Binding SetAnnotationToolCommand}" CommandParameter="Text"
                            Style="{StaticResource SecondaryBtnStyle}" Padding="8,4" Margin="0,0,4,0" FontSize="11"/>
                    <Button Content="▩ 马赛克" Command="{Binding SetAnnotationToolCommand}" CommandParameter="Mosaic"
                            Style="{StaticResource SecondaryBtnStyle}" Padding="8,4" Margin="0,0,12,0" FontSize="11"/>
                    <Separator Width="1" Margin="0,2" Background="{StaticResource BorderBrush}"/>
                    <Button Width="22" Height="22" Margin="8,0,2,0"
                            Background="Red" BorderThickness="0" Cursor="Hand"
                            Click="OnColorButtonClick" Tag="Red"/>
                    <Button Width="22" Height="22" Margin="0,0,2,0"
                            Background="DodgerBlue" BorderThickness="0" Cursor="Hand"
                            Click="OnColorButtonClick" Tag="DodgerBlue"/>
                    <Button Width="22" Height="22" Margin="0,0,2,0"
                            Background="ForestGreen" BorderThickness="0" Cursor="Hand"
                            Click="OnColorButtonClick" Tag="ForestGreen"/>
                    <Button Width="22" Height="22" Margin="0,0,2,0"
                            Background="Orange" BorderThickness="0" Cursor="Hand"
                            Click="OnColorButtonClick" Tag="Orange"/>
                    <Button Width="22" Height="22" Margin="0,0,12,0"
                            Background="Purple" BorderThickness="0" Cursor="Hand"
                            Click="OnColorButtonClick" Tag="Purple"/>
                    <Separator Width="1" Margin="0,2" Background="{StaticResource BorderBrush}"/>
                    <Button Content="↩ 撤销" Command="{Binding UndoAnnotationCommand}"
                            Style="{StaticResource SecondaryBtnStyle}" Padding="8,4" Margin="8,0,4,0" FontSize="11"
                            IsEnabled="{Binding CanUndo}"/>
                    <Button Content="↪ 重做" Command="{Binding RedoAnnotationCommand}"
                            Style="{StaticResource SecondaryBtnStyle}" Padding="8,4" Margin="0,0,4,0" FontSize="11"
                            IsEnabled="{Binding CanRedo}"/>
                    <Button Content="🗑 清除" Command="{Binding ClearAllAnnotationsCommand}"
                            Style="{StaticResource SecondaryBtnStyle}" Padding="8,4" Margin="0,0,12,0" FontSize="11"/>
                    <TextBlock Text="{Binding AnnotationCount, StringFormat='标注: {0}'}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Border>

            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button Content="💾 保存 PNG" Command="{Binding SaveScreenshotCommand}" CommandParameter="png"
                        Style="{StaticResource PrimaryButtonStyle}" Padding="14,8" Margin="0,0,8,0" FontSize="12"/>
                <Button Content="💾 保存 JPG" Command="{Binding SaveScreenshotCommand}" CommandParameter="jpg"
                        Style="{StaticResource PrimaryButtonStyle}" Padding="14,8" Margin="0,0,8,0" FontSize="12"/>
                <Button Content="📋 复制到剪贴板" Command="{Binding CopyScreenshotCommand}"
                        Style="{StaticResource SecondaryBtnStyle}" Padding="14,8" Margin="0,0,8,0" FontSize="12"/>
                <Button Content="❌ 放弃" Command="{Binding DiscardScreenshotCommand}"
                        Style="{StaticResource DangerButtonStyle}" Padding="14,8" FontSize="12"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
