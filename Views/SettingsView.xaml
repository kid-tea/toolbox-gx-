<!--
    SettingsView.xaml - 设置页面
    四个 TabItem 标签页：外观 / 快捷键 / 通知 / 调试 / 关于
    即时预览：外观修改在设置页面内即时生效
    快捷键录制：点击区域进入录制模式 -> 按下新组合键 -> 冲突检测 -> 保存
    即时保存：所有修改直接写入 settings.json，无保存按钮
-->
<UserControl x:Class="Toolbox.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Toolbox.ViewModels"
             Background="{StaticResource ContentBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}">

            <TabItem Header="外观">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Text="设置" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                        <Border Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="主题与语言" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="修改后立即生效，无需点击保存" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding SaveStatus}" Foreground="{StaticResource SuccessBrush}" FontSize="12" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <GroupBox Header="主题风格" Margin="0,0,0,12" Padding="12"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <StackPanel>
                                <TextBlock Text="选择整个工具箱使用的界面风格，修改后立即生效" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <UniformGrid Columns="4" HorizontalAlignment="Left">
                                    <Button Content="经典"
                                            Command="{Binding SetClassicThemeCommand}"
                                            Padding="16,9" Width="150" Margin="0,0,8,0"
                                            BorderThickness="1" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsClassicThemeSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="曜石控制台"
                                            Command="{Binding SetObsidianThemeCommand}"
                                            Padding="16,9" Width="150" Margin="0,0,8,0"
                                            BorderThickness="1" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsObsidianThemeSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="对比专业版"
                                            Command="{Binding SetContrastProThemeCommand}"
                                            Padding="16,9" Width="150" Margin="0,0,8,0"
                                            BorderThickness="1" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsContrastProThemeSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="纸感工具箱"
                                            Command="{Binding SetPaperUtilityThemeCommand}"
                                            Padding="16,9" Width="150"
                                            BorderThickness="1" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPaperUtilityThemeSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="语言" Margin="0,0,0,12" Padding="12"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <StackPanel>
                                <TextBlock Text="当前支持中文和 English 两种界面语言" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <Button Content="切换语言"
                                        Command="{Binding ToggleLanguageCommand}"
                                        Padding="12,8" HorizontalAlignment="Left"
                                        Background="{StaticResource InputBackgroundBrush}"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="主界面外观" Margin="0,0,0,12" Padding="12"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="背景模式" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" Width="180" Margin="0,0,0,8"
                                          Background="{StaticResource InputBackgroundBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          BorderBrush="{StaticResource BorderBrush}">
                                    <ComboBoxItem Content="纯色" IsSelected="True"/>
                                    <ComboBoxItem Content="自定义图片"/>
                                </ComboBox>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="字体类型" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MainFontFamily, UpdateSourceTrigger=PropertyChanged}"
                                         Width="180" Height="28" Margin="0,0,0,8"
                                         Background="{StaticResource InputBackgroundBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" FontSize="12"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="字体大小 / 颜色" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <TextBox Text="{Binding MainFontSize, UpdateSourceTrigger=PropertyChanged}"
                                             Width="60" Height="28" TextAlignment="Center"
                                             Background="{StaticResource InputBackgroundBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             BorderBrush="{StaticResource BorderBrush}" FontSize="12"/>
                                    <TextBox Text="{Binding MainFontColor, UpdateSourceTrigger=PropertyChanged}"
                                             Width="100" Height="28" Margin="8,0,0,0"
                                             Background="{StaticResource InputBackgroundBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             BorderBrush="{StaticResource BorderBrush}" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="悬浮面板外观" Margin="0,0,0,12" Padding="12"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="透明度" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Slider Value="{Binding PanelOpacity, UpdateSourceTrigger=PropertyChanged}"
                                            Minimum="0.1" Maximum="1.0" SmallChange="0.05" LargeChange="0.1"
                                            Width="180" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding PanelOpacity, StringFormat={}{0:P0}}"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="字体大小" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PanelFontSize, UpdateSourceTrigger=PropertyChanged}"
                                         Width="60" Height="28" TextAlignment="Center" Margin="0,0,0,8"
                                         Background="{StaticResource InputBackgroundBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" FontSize="12"/>

                                <CheckBox Grid.Row="2" Grid.Column="1" Content="始终置顶"
                                          IsChecked="{Binding PanelAlwaysOnTop}"
                                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="快捷键">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="点击快捷键区域进入录制模式，按下新组合键保存"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                                   Margin="0,0,0,12" TextWrapping="Wrap"/>

                        <Border Background="{StaticResource DangerBrush}" CornerRadius="4" Padding="8,4"
                                Margin="0,0,0,8"
                                Visibility="{Binding IsRecordingShortcut, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding ShortcutConflictMessage}"
                                       Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        </Border>

                        <GroupBox Header="截屏快捷键" Margin="0,0,0,8" Padding="8"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding ScreenshotShortcut}" IsReadOnly="True"
                                         Background="{StaticResource InputBackgroundBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         Width="180" Height="30" FontSize="14" FontFamily="Consolas"
                                         VerticalContentAlignment="Center" TextAlignment="Center"/>
                                <Button Grid.Column="1" Content="录制" Padding="10,6" Margin="8,0,0,0"
                                        Background="{StaticResource AccentBrush}" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="OnRecordScreenshotShortcut"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="取色器快捷键" Margin="0,0,0,8" Padding="8"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding ColorPickerShortcut}" IsReadOnly="True"
                                         Background="{StaticResource InputBackgroundBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         Width="180" Height="30" FontSize="14" FontFamily="Consolas"
                                         VerticalContentAlignment="Center" TextAlignment="Center"/>
                                <Button Grid.Column="1" Content="录制" Padding="10,6" Margin="8,0,0,0"
                                        Background="{StaticResource AccentBrush}" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="OnRecordColorPickerShortcut"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="窗口置顶快捷键" Padding="8"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding AlwaysOnTopShortcut}" IsReadOnly="True"
                                         Background="{StaticResource InputBackgroundBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         Width="180" Height="30" FontSize="14" FontFamily="Consolas"
                                         VerticalContentAlignment="Center" TextAlignment="Center"/>
                                <Button Grid.Column="1" Content="录制" Padding="10,6" Margin="8,0,0,0"
                                        Background="{StaticResource AccentBrush}" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="OnRecordAlwaysOnTopShortcut"/>
                            </Grid>
                        </GroupBox>

                        <Button Content="取消录制" Command="{Binding CancelRecordingCommand}"
                                Visibility="{Binding IsRecordingShortcut, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,8,0,0" Padding="12,6" HorizontalAlignment="Left"
                                Background="{StaticResource DangerBrush}" Foreground="White"
                                BorderThickness="0" Cursor="Hand"/>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="通知">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <GroupBox Header="总开关" Margin="0,0,0,12" Padding="8"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <CheckBox Content="启用所有通知"
                                      IsChecked="{Binding NotificationsEnabled}"
                                      Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        </GroupBox>

                        <GroupBox Header="默认提示音" Margin="0,0,0,12" Padding="8"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <StackPanel>
                                <ComboBox Width="150" Margin="0,0,0,8"
                                          Background="{StaticResource InputBackgroundBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          BorderBrush="{StaticResource BorderBrush}">
                                    <ComboBoxItem Content="系统默认" IsSelected="True"/>
                                    <ComboBoxItem Content="静音"/>
                                    <ComboBoxItem Content="自定义 WAV"/>
                                </ComboBox>
                                <TextBox Text="{Binding DefaultAlertSoundPath}"
                                         Width="300" Height="26"
                                         Background="{StaticResource InputBackgroundBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         FontSize="12"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="通知模式" Margin="0,0,0,12" Padding="8"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="定时清理通知:" Width="120" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                    <ComboBox Width="150"
                                              Background="{StaticResource InputBackgroundBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              BorderBrush="{StaticResource BorderBrush}">
                                        <ComboBoxItem Content="清理前通知"/>
                                        <ComboBoxItem Content="仅完成后"/>
                                        <ComboBoxItem Content="静默"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="定时关机通知:" Width="120" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                    <ComboBox Width="150"
                                              Background="{StaticResource InputBackgroundBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              BorderBrush="{StaticResource BorderBrush}">
                                        <ComboBoxItem Content="5分钟+1分钟"/>
                                        <ComboBoxItem Content="仅1分钟"/>
                                        <ComboBoxItem Content="不通知"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="任务提醒通知:" Width="120" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                    <ComboBox Width="150"
                                              Background="{StaticResource InputBackgroundBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              BorderBrush="{StaticResource BorderBrush}">
                                        <ComboBoxItem Content="弹窗+提示音"/>
                                        <ComboBoxItem Content="仅弹窗"/>
                                        <ComboBoxItem Content="仅提示音"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="调试">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="调试模式" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                        <Border Background="{StaticResource SidebarBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="12" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="调试模式" FontWeight="Bold" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="开启后可访问标记为「待优化」的功能页面（截屏、磁盘空间分析、任务、AI Agent 检验）。"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <GroupBox Header="待优化功能访问" Margin="0,0,0,12" Padding="8"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <StackPanel>
                                <CheckBox Content="启用待优化功能（截屏 / 磁盘空间分析 / 任务 / AI Agent 检验）"
                                          IsChecked="{Binding DebugMode}"
                                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                <TextBlock Text="注意：这些功能可能存在未修复的缺陷，仅供调试和测试使用。"
                                           Foreground="{StaticResource WarningBrush}" FontSize="11"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </GroupBox>


                        <GroupBox Header="AI Agent Token 数据源" Margin="0,0,0,12" Padding="8"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="统计方式" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" Width="220" Margin="0,0,0,8"
                                          ItemsSource="{Binding AgentTokenDataSourceOptions}"
                                          SelectedItem="{Binding AgentTokenDataSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Background="{StaticResource InputBackgroundBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          BorderBrush="{StaticResource BorderBrush}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="API 提供方" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" Width="220" Margin="0,0,0,8"
                                          ItemsSource="{Binding AgentTokenApiProviderOptions}"
                                          SelectedItem="{Binding AgentTokenApiProvider, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Background="{StaticResource InputBackgroundBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          BorderBrush="{StaticResource BorderBrush}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="模型" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Width="220" Height="28" Margin="0,0,0,8"
                                         Text="{Binding AgentTokenApiModel, UpdateSourceTrigger=PropertyChanged}"
                                         Background="{StaticResource InputBackgroundBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" FontSize="12"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="API Key" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Width="220" Height="28" Margin="0,0,0,8"
                                         Text="{Binding AgentTokenApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Background="{StaticResource InputBackgroundBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" FontSize="12"/>

                                <TextBlock Grid.Row="4" Grid.ColumnSpan="3"
                                           Text="Local 会读取 Codex/Claude 本地 transcript；Api 会按提供方与模型读取官方用量接口。API Key 只保存在本机 settings.json。"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="关于">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <GroupBox Header="版本信息" Margin="0,0,0,12" Padding="8"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <StackPanel>
                                <TextBlock Text="{Binding AppVersion, StringFormat='版本号: {0}'}"
                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"
                                           FontWeight="Bold" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="检查更新" Command="{Binding CheckUpdateCommand}"
                                            IsEnabled="{Binding IsCheckingUpdate, Converter={StaticResource InverseBoolConverter}}"
                                            Padding="12,6"
                                            Background="{StaticResource AccentBrush}" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"/>
                                    <TextBlock Text="{Binding UpdateStatus}"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="操作" Margin="0,0,0,12" Padding="8"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <StackPanel>
                                <Button Content="恢复默认设置" Command="{Binding ResetToDefaultsCommand}"
                                        Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,8"
                                        Background="{StaticResource WarningBrush}" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"/>
                                <Button Content="导出设置" Command="{Binding ExportSettingsCommand}"
                                        Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,8"
                                        Background="{StaticResource InputBackgroundBrush}"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                                <Button Content="卸载指引" Command="{Binding ShowUninstallGuideCommand}"
                                        Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,8"
                                        Background="{StaticResource InputBackgroundBrush}"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                                <Button Content="开源许可" Command="{Binding ShowLicenseCommand}"
                                        Padding="12,6" HorizontalAlignment="Left"
                                        Background="{StaticResource InputBackgroundBrush}"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource DefaultCornerRadius}" Padding="8,4"
                Margin="0,8,0,0">
            <TextBlock Text="{Binding SaveStatus}"
                       Foreground="{StaticResource SuccessBrush}" FontSize="11"/>
        </Border>
    </Grid>
</UserControl>
