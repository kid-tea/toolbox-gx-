<!--
    StartupManagerView.xaml — 开机启动项管理页面
    功能：启动项列表（名称/发布者/路径/影响程度/状态）、搜索过滤、启用禁用开关、
          删除、导出CSV
    影响程度色标：🟢低(绿) 🟡中(黄) 🔴高(红) 🟠文件丢失(橙) ⚫不可用(灰)
-->
<UserControl x:Class="Toolbox.Views.StartupManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Toolbox.Views"
             xmlns:vm="clr-namespace:Toolbox.ViewModels"
             xmlns:svc="clr-namespace:Toolbox.Services"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:StartupManagerViewModel}"
             Background="{StaticResource ContentBrush}">

    <UserControl.Resources>
        <local:ImpactToColorConverter x:Key="ImpactToColorConverter"/>
        <local:ImpactToBackgroundConverter x:Key="ImpactToBackgroundConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- 工具栏 -->
            <RowDefinition Height="Auto"/>
            <!-- 状态栏 -->
            <RowDefinition Height="Auto"/>
            <!-- 启动项列表 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========== 工具栏 ========== -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：操作按钮 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="&#x1F50D; 扫描启动项"
                            Command="{Binding ScanCommand}"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="16,6"
                            Cursor="Hand"
                            FontSize="12"/>
                    <Button Content="导出 CSV"
                            Command="{Binding ExportCsvCommand}"
                            Background="{StaticResource InputBackgroundBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="12,6"
                            Margin="8,0,0,0"
                            Cursor="Hand"
                            FontSize="12"/>
                </StackPanel>

                <!-- 中间：搜索框 -->
                <Grid Grid.Column="1" Margin="16,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource InputBackgroundBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Height="28"
                             Padding="8,4"
                             FontSize="12"
                             VerticalAlignment="Center">
                        <TextBox.Resources>
                            <VisualBrush x:Key="PlaceholderBrush" Stretch="None" AlignmentX="Left">
                                <VisualBrush.Visual>
                                    <TextBlock Text="搜索名称、路径或发布者..."
                                               Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </TextBox.Resources>
                    </TextBox>
                </Grid>

                <!-- 右侧：过滤下拉框 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="来源:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox ItemsSource="{Binding SourceFilters}"
                              SelectedItem="{Binding FilterSource}"
                              Style="{StaticResource {x:Type ComboBox}}"
                              Width="140" FontSize="11"/>

                    <TextBlock Text="影响:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <ComboBox ItemsSource="{Binding ImpactFilters}"
                              SelectedItem="{Binding FilterImpact}"
                              Width="80" FontSize="11"/>

                    <TextBlock Text="状态:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <ComboBox ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding FilterStatus}"
                              Width="80" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== 状态栏 ========== -->
        <Border Grid.Row="1" Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatisticsText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="12" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" Margin="16,0"/>

                <!-- 进度条（扫描时显示） -->
                <ProgressBar Grid.Column="2"
                             Value="{Binding ProgressValue}"
                             Maximum="{Binding ProgressMax}"
                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                             Width="120" Height="6"/>
            </Grid>
        </Border>

        <!-- ========== 启动项列表 ========== -->
        <Border Grid.Row="2" Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="4">
            <ListView ItemsSource="{Binding Entries}"
                      Background="Transparent"
                      BorderThickness="0"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        <Setter Property="Height" Value="48"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.View>
                    <GridView>
                        <!-- 启用/禁用开关 -->
                        <GridViewColumn Header="" Width="48">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  Command="{Binding DataContext.ToggleItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                  CommandParameter="{Binding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Impact}" Value="Unavailable">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- 影响程度色标 -->
                        <GridViewColumn Header="影响" Width="48">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="4,2"
                                            Background="{Binding Impact, Converter={StaticResource ImpactToBackgroundConverter}}"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding ImpactDisplay}"
                                                   Foreground="White"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- 名称 -->
                        <GridViewColumn Header="名称" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- 发布者 -->
                        <GridViewColumn Header="发布者" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Publisher}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- 路径 -->
                        <GridViewColumn Header="路径" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FilePath}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding FilePath}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- 来源 -->
                        <GridViewColumn Header="来源" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SourceDisplay}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- 操作按钮 -->
                        <GridViewColumn Header="" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="&#x1F4C2;"
                                                ToolTip="打开文件位置"
                                                Padding="4,2"
                                                FontSize="12"
                                                Background="Transparent"
                                                Foreground="{StaticResource TextMutedBrush}"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.OpenFileLocationCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="&#x1F5D1;"
                                                ToolTip="删除启动项"
                                                Padding="4,2"
                                                FontSize="12"
                                                Background="Transparent"
                                                Foreground="{StaticResource TextMutedBrush}"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</UserControl>
