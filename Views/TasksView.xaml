<!--
    TasksView.xaml — 任务管理功能页面
    布局：创建任务面板 → 任务列表 → 排序/清除按钮
    任务项：☐勾选 + 🔴重要标记 + 内容 + 时间 + 已完成变灰沉底 + 已暂停虚线
    所有颜色使用 {StaticResource ...} 引用主题
-->
<UserControl x:Class="Toolbox.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Toolbox.ViewModels"
             xmlns:models="clr-namespace:Toolbox.Models"
             Background="{StaticResource ContentBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 创建任务面板 -->
            <RowDefinition Height="Auto"/>   <!-- 状态 + 排序/悬浮面板 -->
            <RowDefinition Height="*"/>      <!-- 任务列表 -->
        </Grid.RowDefinitions>

        <!-- ========== 第1行：创建任务面板 ========== -->
        <Border Grid.Row="0" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource DefaultCornerRadius}" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <!-- 表单标题 -->
                <TextBlock Text="创建任务" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                <!-- 内容输入 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="内容:" VerticalAlignment="Center" Width="50"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                    <TextBox Text="{Binding NewTaskContent, UpdateSourceTrigger=PropertyChanged}"
                             Width="300" Height="28"
                             Background="{StaticResource InputBackgroundBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             FontSize="13"/>
                </StackPanel>

                <!-- 时间 + 重复 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="时间:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <DatePicker SelectedDate="{Binding NewTaskDate}" Width="126" Height="30" Margin="0,0,8,0"/>
                        <TextBox x:Name="HourTextBox" Width="46" Height="30" MaxLength="2"
                                 HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 FontSize="13" Text="{Binding NewTaskHour, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text=":" Margin="6,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox x:Name="MinuteTextBox" Width="46" Height="30" MaxLength="2"
                                 HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 FontSize="13" Text="{Binding NewTaskMinute, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text=":" Margin="6,0" VerticalAlignment="Center" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox x:Name="SecondTextBox" Width="46" Height="30" MaxLength="2"
                                 HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 FontSize="13" Text="{Binding NewTaskSecond, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2" Text="重复:" VerticalAlignment="Center" Margin="12,0,4,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                    <ComboBox Grid.Column="3" SelectedValue="{Binding NewTaskRepeatMode}" SelectedValuePath="Tag"
                              Width="110" Height="30"
                              Background="{StaticResource InputBackgroundBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              BorderBrush="{StaticResource BorderBrush}">
                        <ComboBoxItem Content="一次" Tag="{x:Static models:TaskRepeatMode.Once}"/>
                        <ComboBoxItem Content="每天" Tag="{x:Static models:TaskRepeatMode.Daily}"/>
                        <ComboBoxItem Content="每周" Tag="{x:Static models:TaskRepeatMode.Weekly}"/>
                        <ComboBoxItem Content="自定义" Tag="{x:Static models:TaskRepeatMode.Custom}"/>
                    </ComboBox>
                </Grid>

                <!-- 每周重复选择（仅每周模式可见） -->
                <StackPanel Orientation="Horizontal" Margin="50,0,0,8"
                            Visibility="Collapsed">
                    <CheckBox Content="一" IsChecked="{Binding WeeklyMon}" Margin="0,0,6,0"
                              Foreground="{StaticResource TextPrimaryBrush}" FontSize="11"/>
                    <CheckBox Content="二" IsChecked="{Binding WeeklyTue}" Margin="0,0,6,0"
                              Foreground="{StaticResource TextPrimaryBrush}" FontSize="11"/>
                    <CheckBox Content="三" IsChecked="{Binding WeeklyWed}" Margin="0,0,6,0"
                              Foreground="{StaticResource TextPrimaryBrush}" FontSize="11"/>
                    <CheckBox Content="四" IsChecked="{Binding WeeklyThu}" Margin="0,0,6,0"
                              Foreground="{StaticResource TextPrimaryBrush}" FontSize="11"/>
                    <CheckBox Content="五" IsChecked="{Binding WeeklyFri}" Margin="0,0,6,0"
                              Foreground="{StaticResource TextPrimaryBrush}" FontSize="11"/>
                    <CheckBox Content="六" IsChecked="{Binding WeeklySat}" Margin="0,0,6,0"
                              Foreground="{StaticResource TextPrimaryBrush}" FontSize="11"/>
                    <CheckBox Content="日" IsChecked="{Binding WeeklySun}"
                              Foreground="{StaticResource TextPrimaryBrush}" FontSize="11"/>
                </StackPanel>

                <!-- 自定义间隔 + 重要性 + 提示音 -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="自定义间隔:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBox Text="{Binding NewTaskCustomInterval, UpdateSourceTrigger=PropertyChanged}"
                                 Width="54" Height="28"
                                 HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                 Background="{StaticResource InputBackgroundBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 FontSize="12"/>
                        <ComboBox SelectedValue="{Binding NewTaskCustomIntervalUnit}" SelectedValuePath="Content"
                                  Width="58" Height="28" Margin="6,0,0,0"
                                  Background="{StaticResource InputBackgroundBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <ComboBoxItem Content="天"/>
                            <ComboBoxItem Content="小时"/>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Grid.Column="2" Text="重要性:" VerticalAlignment="Center" Margin="8,0,4,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <ComboBox Grid.Column="3" SelectedValue="{Binding NewTaskImportance}" SelectedValuePath="Tag"
                              Width="100" Height="28"
                              Background="{StaticResource InputBackgroundBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              BorderBrush="{StaticResource BorderBrush}">
                        <ComboBoxItem Content="普通" Tag="{x:Static models:TaskImportance.Normal}"/>
                        <ComboBoxItem Content="重要" Tag="{x:Static models:TaskImportance.Important}"/>
                    </ComboBox>

                    <TextBlock Grid.Column="4" Text="提示音:" VerticalAlignment="Center" Margin="8,0,4,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <ComboBox Grid.Column="5" SelectedValue="{Binding NewTaskAlertSound}" SelectedValuePath="Tag"
                              Width="110" Height="28"
                              Background="{StaticResource InputBackgroundBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              BorderBrush="{StaticResource BorderBrush}">
                        <ComboBoxItem Content="系统默认" Tag="SystemDefault"/>
                        <ComboBoxItem Content="静音" Tag="Silent"/>
                        <ComboBoxItem Content="自定义WAV" Tag="CustomWav"/>
                    </ComboBox>
                </Grid>

                <!-- 自定义间隔错误提示 -->
                <TextBlock Text="{Binding CustomIntervalError}"
                           Foreground="{StaticResource DangerBrush}" FontSize="11"
                           Margin="70,4,0,0"
                           Visibility="{Binding IsCustomIntervalValid, Converter={StaticResource InvertBoolToVisibilityConverter}}"/>

                <!-- 添加按钮 -->
                <Button Content="+ 添加任务" Command="{Binding AddTaskCommand}"
                        Margin="0,10,0,0" Padding="16,6"
                        Background="{StaticResource AccentBrush}" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <!-- ========== 第2行：状态栏 + 工具栏 ========== -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="{Binding SortByImportance, StringFormat=当前排序：{0}}"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Content="切换排序方式"
                        Command="{Binding ToggleSortCommand}"
                        Margin="0,0,8,0" Padding="8,4" FontSize="11"
                        Background="{StaticResource InputBackgroundBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                <Button Content="悬浮面板" Command="{Binding ToggleFloatingPanelCommand}"
                        Margin="0,0,8,0" Padding="8,4" FontSize="11"
                        Background="{StaticResource InputBackgroundBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                <Button Content="清除已完成" Command="{Binding ClearCompletedTasksCommand}"
                        Padding="8,4" FontSize="11"
                        Background="{StaticResource DangerBrush}" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ========== 第3行：任务列表 ========== -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource DefaultCornerRadius}" Padding="8">
            <Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Tasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,4" Padding="6"
                                    CornerRadius="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 勾选框 -->
                                    <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                              IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                              Margin="0,0,8,0"
                                              Click="OnToggleTaskCompleteClick"/>

                                    <!-- 任务信息 -->
                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- 重要标记 -->
                                            <Border Background="{StaticResource DangerBrush}"
                                                    CornerRadius="2" Padding="2,0"
                                                    Visibility="{Binding Importance, Converter={StaticResource ImportanceToVisibilityConverter}}"
                                                    Margin="0,0,4,0">
                                                <TextBlock Text="IMPORTANT" Foreground="White" FontSize="8"/>
                                            </Border>

                                            <!-- 内容（已完成划线，已暂停虚线） -->
                                            <TextBlock Text="{Binding Content}"
                                                       FontSize="13" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource CompletedBrush}"/>
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                                <Setter Property="TextDecorations" Value="Underline"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding NextTriggerTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                       Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                            <TextBlock Text="{Binding RepeatMode, StringFormat=' | 重复: {0}'}"
                                                       Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                                                       Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 操作按钮 -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="⏸"
                                                Tag="{Binding}"
                                                Click="OnPauseTaskClick"
                                                Padding="6,2" FontSize="11"
                                                Background="Transparent"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                BorderThickness="0" Cursor="Hand"/>
                                        <Button Content="✕"
                                                Tag="{Binding}"
                                                Click="OnDeleteTaskClick"
                                                Padding="6,2" FontSize="11"
                                                Background="Transparent"
                                                Foreground="{StaticResource DangerBrush}"
                                                BorderThickness="0" Cursor="Hand"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 空状态 -->
            <TextBlock Text="暂无任务 — 在上方创建新任务"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding TaskCount, Converter={StaticResource InvertBoolToVisibilityConverter}, FallbackValue=Visible}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
